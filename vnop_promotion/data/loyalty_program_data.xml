<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- 1. Khuyến mãi khai trương - giảm 20% toàn bộ đơn (tự động, mọi kênh) -->
    <record id="promo_khai_truong" model="loyalty.program">
        <field name="name">KM Khai trương - Giảm 20% toàn bộ đơn</field>
        <field name="program_type">promotion</field>
        <field name="applies_on">current</field>
        <field name="trigger">auto</field>
        <field name="channel_type">all</field>
    </record>
    <record id="promo_khai_truong_rule" model="loyalty.rule">
        <field name="program_id" ref="promo_khai_truong"/>
        <field name="minimum_qty">1</field>
        <field name="minimum_amount">0</field>
        <field name="reward_point_amount">1</field>
        <field name="reward_point_mode">order</field>
    </record>
    <record id="promo_khai_truong_reward" model="loyalty.reward">
        <field name="program_id" ref="promo_khai_truong"/>
        <field name="reward_type">discount</field>
        <field name="discount">20</field>
        <field name="discount_mode">percent</field>
        <field name="discount_applicability">order</field>
        <field name="required_points">1</field>
    </record>

    <!-- 2. Ưu đãi khách buôn - giảm 25% khi đơn từ 5 triệu (kênh bán buôn) -->
