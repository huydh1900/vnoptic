<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="loyalty_program_view_form_channel" model="ir.ui.view">
        <field name="name">loyalty.program.form.channel</field>
        <field name="model">loyalty.program</field>
        <field name="inherit_id" ref="loyalty.loyalty_program_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='program_type']" position="after">
                <field name="channel_type"/>
            </xpath>
            <xpath expr="//div[@class='oe_title']/h1/field[@name='name']" position="attributes">
                <attribute name="placeholder">Black Friday - Giảm 30% sản phẩm rẻ nhất</attribute>
            </xpath>
        </field>
    </record>

    <record id="loyalty_program_view_tree_channel" model="ir.ui.view">
        <field name="name">loyalty.program.list.channel</field>
        <field name="model">loyalty.program</field>
        <field name="inherit_id" ref="loyalty.loyalty_program_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='program_type']" position="after">
                <field name="channel_type"/>
            </xpath>
        </field>
    </record>

</odoo>
