        <field name="name">Cước vận chuyển quốc tế</field>
        <field name="default_code">LC-VCQT</field>
        <field name="type">service</field>
        <field name="categ_id" ref="product_category_landed_cost"/>
        <field name="landed_cost_ok" eval="True"/>
        <field name="split_method_landed_cost">by_current_cost_price</field>
        <field name="list_price">0</field>
        <field name="sale_ok" eval="False"/>
        <field name="purchase_ok" eval="True"/>
    </record>

