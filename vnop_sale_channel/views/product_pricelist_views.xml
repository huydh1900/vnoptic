<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_pricelist_view_tree_channel" model="ir.ui.view">
        <field name="name">product.pricelist.list.channel</field>
        <field name="model">product.pricelist</field>
        <field name="inherit_id" ref="product.product_pricelist_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="channel_type"/>
            </xpath>
        </field>
    </record>

    <record id="product_pricelist_view_form_channel" model="ir.ui.view">
        <field name="name">product.pricelist.form.channel</field>
        <field name="model">product.pricelist</field>
        <field name="inherit_id" ref="product.product_pricelist_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='currency_id']" position="after">
                <field name="channel_type"/>
            </xpath>
        </field>
    </record>

</odoo>
