<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_sale_order_line_import_wizard_form" model="ir.ui.view">
        <field name="name">sale.order.line.import.wizard.form</field>
        <field name="model">sale.order.line.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import dòng đơn bán">
                <field name="order_id" invisible="1"/>
                <field name="state" invisible="1"/>

                <group invisible="state != 'upload'">
                    <field name="file_data" filename="file_name"/>
                    <field name="file_name" invisible="1"/>
                </group>

                <group invisible="state != 'validated'">
                    <field name="validated_count"/>
                    <field name="error_text" invisible="not error_text" widget="text"/>
                </group>

                <group invisible="state != 'done'">
                    <field name="imported_count"/>
                    <field name="error_text" invisible="not error_text" widget="text"/>
                </group>

                <footer invisible="state != 'upload'">
                    <button name="action_validate" type="object" string="Kiểm thử" class="btn-warning" icon="fa-check-circle"/>
                    <button name="action_import" type="object" string="Import" class="btn-success" icon="fa-upload"/>
                    <button string="Đóng" class="btn-secondary" special="cancel"/>
                </footer>
                <footer invisible="state != 'validated'">
                    <button name="action_import" type="object" string="Import" class="btn-success" icon="fa-upload"
                            invisible="error_text"/>
                    <button name="action_back_upload" type="object" string="Quay lại" class="btn-info" icon="fa-arrow-left"/>
                    <button string="Đóng" class="btn-secondary" special="cancel"/>
                </footer>
                <footer invisible="state != 'done'">
                    <button string="Đóng" class="btn-primary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
