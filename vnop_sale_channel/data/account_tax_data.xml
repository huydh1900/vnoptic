<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="tax_group_vat" model="account.tax.group">
        <field name="name">Thuế GTGT</field>
        <field name="sequence">10</field>
        <field name="country_id" ref="base.vn"/>
    </record>

    <record id="tax_sale_5" model="account.tax">
        <field name="name">Thuế GTGT 5%</field>
        <field name="amount">5</field>
        <field name="amount_type">percent</field>
        <field name="type_tax_use">sale</field>
        <field name="price_include_override">tax_excluded</field>
        <field name="tax_group_id" ref="tax_group_vat"/>
        <field name="country_id" ref="base.vn"/>
    </record>

    <record id="tax_sale_8" model="account.tax">
        <field name="name">Thuế GTGT 8%</field>
        <field name="amount">8</field>
        <field name="amount_type">percent</field>
        <field name="type_tax_use">sale</field>
        <field name="price_include_override">tax_excluded</field>
        <field name="tax_group_id" ref="tax_group_vat"/>
        <field name="country_id" ref="base.vn"/>
    </record>

    <record id="tax_sale_10" model="account.tax">
        <field name="name">Thuế GTGT 10%</field>
        <field name="amount">10</field>
        <field name="amount_type">percent</field>
        <field name="type_tax_use">sale</field>
        <field name="price_include_override">tax_excluded</field>
        <field name="tax_group_id" ref="tax_group_vat"/>
        <field name="country_id" ref="base.vn"/>
    </record>

</odoo>
