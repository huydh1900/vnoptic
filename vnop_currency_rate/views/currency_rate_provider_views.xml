<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="currency_rate_provider_form" model="ir.ui.view">
        <field name="name">currency.rate.provider.form</field>
        <field name="model">currency.rate.provider</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_sync" type="object" string="Đồng bộ ngay" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="source"/>
                            <field name="api_key" invisible="source != 'exchangerate_api'"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="currency_ids" widget="many2many_tags"/>
                            <field name="last_sync" readonly="1"/>
                        </group>
                    </group>
                    <group string="Log">
                        <field name="log" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="currency_rate_provider_list" model="ir.ui.view">
        <field name="name">currency.rate.provider.list</field>
        <field name="model">currency.rate.provider</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="source"/>
                <field name="active"/>
                <field name="last_sync"/>
            </list>
        </field>
    </record>

    <record id="currency_rate_provider_action" model="ir.actions.act_window">
        <field name="name">Nhà cung cấp tỷ giá</field>
        <field name="res_model">currency.rate.provider</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_currency_rate_provider"
              name="Nhà cung cấp tỷ giá"
              parent="account.menu_finance_configuration"
              action="currency_rate_provider_action"
              sequence="99"/>
</odoo>
