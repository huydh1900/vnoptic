<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_pos_order_optical" model="ir.sequence">
            <field name="name">POS Mắt kính - Phiếu bán hàng</field>
            <field name="code">pos.order.optical</field>
            <field name="prefix">POS/MK/%(year)s/</field>
            <field name="padding">6</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
            <field name="implementation">no_gap</field>
        </record>

        <record id="seq_pos_session_optical" model="ir.sequence">
            <field name="name">POS Mắt kính - Phiên</field>
            <field name="code">pos.session.optical</field>
            <field name="prefix">SS/MK/%(year)s%(month)s/</field>
            <field name="padding">5</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
        </record>

    </data>
</odoo>
