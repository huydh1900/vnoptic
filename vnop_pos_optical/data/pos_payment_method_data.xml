<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="payment_method_cash_optical" model="pos.payment.method">
            <field name="name">Tiền mặt</field>
            <field name="is_cash_count" eval="True"/>
            <field name="split_transactions" eval="False"/>
        </record>

        <record id="payment_method_bank_transfer" model="pos.payment.method">
            <field name="name">Chuyển khoản ngân hàng</field>
            <field name="is_cash_count" eval="False"/>
        </record>

        <record id="payment_method_card_pos" model="pos.payment.method">
            <field name="name">Quẹt thẻ (POS Bank)</field>
            <field name="is_cash_count" eval="False"/>
        </record>

        <record id="payment_method_momo" model="pos.payment.method">
            <field name="name">Ví MoMo</field>
            <field name="is_cash_count" eval="False"/>
        </record>

        <record id="payment_method_vnpay" model="pos.payment.method">
            <field name="name">VNPay</field>
            <field name="is_cash_count" eval="False"/>
            <field name="use_payment_terminal">vnpay</field>
            <field name="journal_id" ref="journal_pos_optical_bank"/>
        </record>

        <record id="payment_method_zalopay" model="pos.payment.method">
            <field name="name">ZaloPay</field>
            <field name="is_cash_count" eval="False"/>
        </record>

        <record id="payment_method_voucher" model="pos.payment.method">
            <field name="name">Voucher / Phiếu quà tặng</field>
            <field name="is_cash_count" eval="False"/>
        </record>

    </data>
</odoo>
