<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_form_view_optical_lens" model="ir.ui.view">
        <field name="name">product.template.form.optical.lens</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="point_of_sale.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='pos']/group/group[@name='pos']" position="inside">
                <field name="is_optical_lens"/>
            </xpath>
        </field>
    </record>

</odoo>
