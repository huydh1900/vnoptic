<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="purchase_offer_tree_view" model="ir.ui.view">
        <field name="name">purchase.offer.tree</field>
        <field name="model">purchase.offer</field>
        <field name="arch" type="xml">
            <list string="Đề nghị mua hàng">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="contract_id"/>
                <field name="follow_up_date"/>
                <field name="total_qty"/>
                <field name="total_qty_received" optional="show"/>
                <field name="amount_total" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="state"
                       widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'waiting_approval'"
                       decoration-success="state in ('approved', 'converted')"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="purchase_offer_form_view" model="ir.ui.view">
        <field name="name">purchase.offer.form</field>
        <field name="model">purchase.offer</field>
        <field name="arch" type="xml">
            <form string="Đề nghị mua hàng">
                <header>
                    <button name="action_submit" type="object" string="Gửi duyệt" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Phê duyệt" class="oe_highlight" invisible="state != 'waiting_approval'"/>
                    <button name="action_request_revision" type="object" string="Yêu cầu chỉnh sửa" class="btn-warning" invisible="state != 'waiting_approval'"/>
                    <button name="action_cancel" type="object" string="Hủy" class="btn-danger" invisible="state in ('cancelled', 'converted')" confirm="Bạn có chắc chắn muốn hủy đề nghị mua hàng này không?"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,waiting_approval,approved,converted,cancelled"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_contract" type="object" class="oe_stat_button" icon="fa-file-text-o" invisible="not contract_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Hợp đồng</span>
                            </div>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group string="Thông tin chung" col="2">
                        <group>
                            <field name="partner_ref" readonly="state not in ('draft', 'waiting_approval')"/>
                            <field name="partner_id" options="{'no_create': True}" readonly="state not in ('draft', 'waiting_approval')"/>
                            <field name="follow_up_date" readonly="state not in ('draft', 'waiting_approval')"/>
                            <field name="contract_id" readonly="1" invisible="not contract_id"/>
                        </group>
                        <group>
                            <field name="currency_id" readonly="state not in ('draft', 'waiting_approval')"/>
                            <field name="exchange_rate" readonly="state not in ('draft', 'waiting_approval')"/>
                            <field name="total_qty" readonly="1"/>
                            <field name="total_qty_received" readonly="1"/>
                        </group>
                    </group>

                    <group col="2">
                        <group string="Khởi tạo">
                            <field name="create_uid" string="Người tạo" widget="many2one_avatar_user" readonly="1"/>
                            <field name="create_date" string="Ngày tạo" readonly="1"/>
                        </group>
                        <group string="Phê duyệt">
                            <field name="approved_by"/>
                            <field name="approved_date" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Sản phẩm">
                            <div class="mb-2" invisible="state not in ('draft', 'waiting_approval')">
                                <button name="action_download_template" type="object"
                                        string="Tải template mẫu" icon="fa-download"
                                        class="btn-link"/>
                                <button name="action_import_lines_excel" type="object"
                                        string="Import Excel" icon="fa-upload"
                                        class="btn-link"/>
                            </div>
                            <field name="line_ids" readonly="state not in ('draft', 'waiting_approval')">
                                <list editable="bottom">
                                    <field name="product_id" domain="[('product_tmpl_id.primary_supplier_id', '=', parent.partner_id)]"/>
                                    <field name="description" optional="hide"/>
                                    <field name="uom_id" optional="hide"/>
                                    <field name="quantity"/>
                                    <field name="qty_received" readonly="1" column_invisible="not parent.has_received"/>
                                    <field name="expected_price"/>
                                    <field name="taxes_id" widget="many2many_tags" optional="show"
                                           domain="[('type_tax_use', '=', 'purchase')]"/>
                                    <field name="subtotal"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                            <group>
                                <group/>
                                <group class="oe_subtotal_footer">
                                    <field name="amount_untaxed" widget="monetary"/>
                                    <field name="amount_tax" widget="monetary"/>
                                    <field name="amount_total" widget="monetary"/>
                                    <field name="amount_total_vnd" nolabel="1" colspan="2"
                                           invisible="not exchange_rate or exchange_rate == 1"/>
                                    <field name="amount_text_vi" nolabel="1" colspan="2" readonly="1"
                                           class="fst-italic text-muted"/>
                                </group>
                            </group>
                        </page>
                        <page string="Ghi chú">
                            <group>
                                <field name="note" placeholder="Nhập ghi chú nội bộ..." readonly="state not in ('draft', 'waiting_approval')"/>
                                <field name="revision_reason" invisible="not revision_reason"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <record id="purchase_offer_action" model="ir.actions.act_window">
        <field name="name">Đề nghị mua hàng</field>
        <field name="res_model">purchase.offer</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="purchase_offer_menu"
              name="Đề nghị mua hàng"
              parent="purchase.menu_procurement_management"
              action="purchase_offer_action"
              sequence="1"/>

</odoo>
