<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="vnoptic_contract_tree_view" model="ir.ui.view">
        <field name="name">vnoptic.contract.tree</field>
        <field name="model">contract</field>
        <field name="arch" type="xml">
            <list string="Hợp đồng mua hàng">
                <field name="number"/>
                <field name="name"/>
                <field name="partner_ref"/>
                <field name="partner_id"/>
                <field name="total_qty"/>
                <field name="total_received_qty" decoration-success="total_received_qty &gt; 0"/>
                <field name="total_missing_qty" decoration-danger="total_missing_qty &gt; 0"/>
                <field name="amount_total"/>
                <field name="sign_date"/>

                <field name="type_contract"
                       widget="badge"
                       decoration-info="type_contract == 'domestic'"
                       decoration-primary="type_contract == 'foreign'"/>

                <field name="currency_id" column_invisible="1"/>
                <field name="state"
                       widget="badge"
                       decoration-warning="state == 'waiting'"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'cancel'"/>
            </list>
        </field>
    </record>


    <record id="vnoptic_contract_form_view" model="ir.ui.view">
        <field name="name">vnoptic.contract.form</field>
        <field name="model">contract</field>
        <field name="arch" type="xml">
            <form string="Hợp đồng mua hàng">
                <header>
                    <button name="action_approve"
                            type="object"
                            string="Phê duyệt"
                            class="oe_highlight"
                            invisible="state != 'waiting'"/>

                    <button name="action_submit"
                            type="object"
                            string="Gửi duyệt"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_request_revision"
                            type="object"
                            string="Yêu cầu chỉnh sửa"
                            class="btn-secondary"
                            invisible="state != 'approved'"/>

                    <button name="action_allow_revision"
                            type="object"
                            string="Cho phép chỉnh sửa"
                            class="oe_highlight"
                            invisible="state != 'revision_requested'"/>

                    <button name="action_cancel"
                            type="object"
                            string="Hủy hợp đồng"
                            class="btn-danger"
                            invisible="state == 'cancel'"
                            confirm="Bạn có chắc chắn muốn hủy hợp đồng này không?"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,waiting,approved,revision_requested,cancel"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_product"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-cubes">
                            <field name="product_count" widget="statinfo"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Tên hợp đồng..." readonly="state != 'draft'"
                                   class="vnop_required_hint"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Thông tin chung">
                            <field name="number" placeholder="Số hợp đồng..." readonly="state != 'draft'"/>
                            <field name="sign_date" readonly="state != 'draft'"/>
                            <field name="type_contract" readonly="state != 'draft'"/>
                            <field name="currency_id" readonly="state != 'draft'"/>
                            <field name="total_qty" readonly="1"/>
                            <field name="total_received_qty" readonly="1" decoration-success="total_received_qty &gt; 0"/>
                            <field name="total_missing_qty" readonly="1" decoration-danger="total_missing_qty &gt; 0"/>
                            <field name="amount_total" widget="monetary" readonly="1"/>
                        </group>

                        <group string="Nhà cung cấp">
                            <field name="partner_id" options="{'no_create': True}" readonly="state != 'draft'"
                                   class="vnop_required_hint"/>
                            <field name="partner_ref" readonly="state != 'draft'"/>
                            <field name="shipment_date" readonly="state != 'draft'" class="vnop_required_hint"/>
                            <field name="attachment_ids"
                                   widget="many2many_binary"
                                   class="vnop_contract_attachment_preview"
                                   readonly="state != 'draft'"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Giao hàng">
                            <group>
                                <group string="Giao hàng">
                                    <field name="incoterm_id" readonly="state != 'draft'"/>
                                    <field name="port_of_loading" readonly="state != 'draft'"/>
                                    <field name="destination" readonly="state != 'draft'"/>
                                    <field name="partial_shipment" readonly="state != 'draft'"/>
                                    <field name="origin_country_id" readonly="state != 'draft'"/>
                                    <field name="quality_requirements" readonly="state != 'draft'"
                                           placeholder="Yêu cầu chất lượng..."/>
                                    <field name="packing" readonly="state != 'draft'"
                                           placeholder="Quy cách đóng gói..."/>
                                </group>
                            </group>
                        </page>

                        <page string="Thanh toán">
                            <group>
                                <group string="Thanh toán / Ngân hàng">
                                    <field name="payment_term_id" readonly="state != 'draft'"/>
                                    <field name="remittance" readonly="state != 'draft'"
                                           placeholder="Mô tả phương thức thanh toán..."/>
                                    <field name="beneficiary_bank_id" readonly="state != 'draft'"/>
                                    <field name="beneficiary_name" readonly="state != 'draft'"/>
                                    <field name="advising_bank_name" readonly="state != 'draft'"/>
                                    <field name="branch_code" readonly="state != 'draft'"/>
                                    <field name="bank_address" readonly="state != 'draft'"/>
                                    <field name="account_no" readonly="state != 'draft'"/>
                                    <field name="swift_code" readonly="state != 'draft'"/>
                                </group>
                            </group>
                        </page>

                        <page string="Thông tin bổ sung">
                            <group>
                                <field name="company_id" readonly="1"/>
                                <field name="create_uid" readonly="1"/>
                                <field name="create_date" readonly="1"/>
                                <field name="approved_by" widget="many2one_avatar_user" readonly="1"/>
                                <field name="approved_date" readonly="1"/>
                            </group>
                        </page>

                        <page string="Ghi chú">
                            <field name="note" nolabel="1" widget="html" readonly="state != 'draft'"/>
                        </page>

                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>


    <!-- ====== ACTION + MENU (Purchase) ====== -->
    <record id="vnoptic_contract_action" model="ir.actions.act_window">
        <field name="name">Hợp đồng mua hàng</field>
        <field name="res_model">contract</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
    </record>


    <menuitem id="vnoptic_contract_menu"
              name="Hợp đồng mua hàng"
              parent="purchase.menu_procurement_management"
              action="vnoptic_contract_action"
              sequence="2"/>

</odoo>
