<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="seq_stock_otk" model="ir.sequence">
        <field name="name">Stock OTK</field>
        <field name="code">stock.otk</field>
        <field name="prefix">OTK/%(year)s/%(month)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_stock_otk_log" model="ir.sequence">
        <field name="name">Stock OTK Log</field>
        <field name="code">stock.otk.log</field>
        <field name="prefix">OTK/%(year)s/%(month)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
