<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_stock_otk_log_list" model="ir.ui.view">
        <field name="name">stock.otk.log.list</field>
        <field name="model">stock.otk.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="date"/>
                <field name="picking_id"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="view_stock_otk_log_form" model="ir.ui.view">
        <field name="name">stock.otk.log.form</field>
        <field name="model">stock.otk.log</field>
        <field name="arch" type="xml">
            <form string="Lần OTK">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="picking_id"/>
                            <field name="purchase_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="user_id"/>
                            <field name="transfer_ok_id" invisible="not transfer_ok_id"/>
                            <field name="transfer_ng_id" invisible="not transfer_ng_id"/>
                        </group>
                    </group>
                    <field name="line_ids">
                        <list create="0" delete="0">
                            <field name="product_id"/>
                            <field name="uom_id" optional="hide"/>
                            <field name="qty_demand" sum="Tổng SL yêu cầu"/>
                            <field name="qty_otk" sum="Tổng SL kiểm"/>
                            <field name="qty_ng" class="text-danger" sum="Tổng SL không đạt"/>
                            <field name="qty_ok" class="text-success" sum="Tổng SL đạt"/>
                            <field name="qty_remaining" class="text-warning" sum="Tổng SL dư"/>
                            <field name="is_extra" optional="show"/>
                            <field name="action_type" optional="show"/>
                            <field name="note"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_stock_otk_log" model="ir.actions.act_window">
        <field name="name">Lần OTK</field>
        <field name="res_model">stock.otk.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
