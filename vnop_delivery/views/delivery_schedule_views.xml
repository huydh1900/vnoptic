<odoo>
    <record id="delivery_schedule_tree_view" model="ir.ui.view">
        <field name="name">delivery.schedule.tree</field>
        <field name="model">delivery.schedule</field>
        <field name="arch" type="xml">
            <list string="Lịch giao hàng">
                <field name="bill_number"/>
                <field name="purchase_ids" widget="many2many_tags"/>
                <field name="contract_ids" widget="many2many_tags"/>
                <field name="partner_id"/>
                <field name="delivery_datetime"/>
                <field name="qty_planned_total"/>
                <field name="qty_received_total"/>
                <field name="declaration_date"/>
                <field name="declaration_number"/>
                <field name="state"
                       widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'confirmed'"/>
            </list>
        </field>
    </record>

    <record id="delivery_schedule_form_view" model="ir.ui.view">
        <field name="name">delivery.schedule.form</field>
        <field name="model">delivery.schedule</field>
        <field name="arch" type="xml">
            <form string="Lịch giao hàng">
                <header>
                    <button name="action_confirmed"
                            type="object"
                            string="Xác nhận hàng về"
                            invisible="state != 'draft'"
                            class="oe_highlight"/>
                    <button name="action_create_receipt"
                            type="object"
                            string="Tạo phiếu nhập kho"
                            invisible="state != 'confirmed'"
                            class="oe_highlight"
                            icon="fa-sign-in"/>
                    <button name="action_create_otk_sessions"
                            type="object"
                            string="Tạo OTK theo lịch"
                            invisible="state != 'confirmed'"
                            class="btn-secondary"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_contract" type="object"
                                icon="fa-file-text-o"
                                string="Hợp đồng" invisible="not contract_ids"/>
                        <button name="action_view_pickings" type="object"
                                icon="fa-truck"
                                invisible="not purchase_ids">
                            <field name="picking_count" widget="statinfo" string="Phiếu nhập kho"/>
                        </button>
                        <button name="action_view_otk_sessions" type="object"
                                icon="fa-check-square-o">
                            <field name="otk_session_count" widget="statinfo" string="Lần OTK"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="bill_number" string="Số vận đơn"/>
                        <h1>
                            <field name="bill_number"/>
                        </h1>
                    </div>

                    <group>
                        <group name="delivery_info" string="Thông tin vận chuyển">
                            <field name="partner_id"
                                   domain="[('supplier_rank','>',0)]" options="{'no_create': True}"
                                   readonly="context.get('from_purchase')"/>
                            <field name="partner_ref"/>
                            <field name="purchase_ids"
                                   widget="many2many_tags"
                                   domain="[('partner_id', '=', partner_id), ('state', 'in', ('purchase', 'done')), ('contract_id', '!=', False)]"
                                   readonly="state != 'draft'"/>
                            <field name="contract_ids" widget="many2many_tags" readonly="1"/>
                            <field name="delivery_datetime"/>
                            <field name="description" placeholder="Nhập ghi chú nội bộ hoặc hướng dẫn giao hàng..."/>
                            <field name="create_date" readonly="1" string="Thời gian tạo"/>
                        </group>
                        <group name="customs_info" string="Thông tin Hải quan">
                            <field name="declaration_number"/>
                            <field name="declaration_date"/>
                            <field name="total_declaration_amount"/>
                        </group>
                    </group>

                    <group>
                        <group string="Phí bổ sung &amp; tổng quan">
                            <label for="insurance_fee"/>
                            <div class="o_row">
                                <field name="insurance_fee"/>
                                <span>VND</span>
                            </div>
                            <label for="environment_fee"/>
                            <div class="o_row">
                                <field name="environment_fee"/>
                                <span>VND</span>
                            </div>
                            <field name="qty_planned_total" readonly="1"/>
                            <field name="qty_received_total" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Chi tiết hàng giao">
                            <field name="allocation_ids">
                                <list editable="bottom" create="0">
                                    <field name="purchase_line_id" column_invisible="1"/>
                                    <field name="purchase_id" readonly="1"/>
                                    <field name="contract_id"
                                           domain="[('id', '=', purchase_id.contract_id)]"
                                           options="{'no_create': True}"/>
                                    <field name="product_id" readonly="1"/>
                                    <field name="uom_id" readonly="1"/>
                                    <field name="qty_po" readonly="1"/>
                                    <field name="qty_planned"/>
                                    <field name="qty_received" readonly="1" invisible="qty_received == 0"/>
                                    <field name="qty_passed" readonly="1" invisible="qty_passed == 0"/>
                                    <field name="qty_failed" readonly="1" invisible="qty_failed == 0"/>
                                    <field name="qty_remaining_to_receive" readonly="1" invisible="qty_remaining_to_receive == 0"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="delivery_schedule_view_calendar" model="ir.ui.view">
        <field name="name">delivery.schedule.view.calendar</field>
        <field name="model">delivery.schedule</field>
        <field name="arch" type="xml">
            <calendar date_start="delivery_datetime" color="state">
                <field name="bill_number"/>
                <field name="partner_id"/>
            </calendar>
        </field>
    </record>

    <record id="delivery_schedule_view_gantt" model="ir.ui.view">
        <field name="name">delivery.schedule.view.gantt</field>
        <field name="model">delivery.schedule</field>
        <field name="arch" type="xml">
            <gantt
                    date_start="delivery_datetime"
                    date_stop="delivery_datetime"
                    create="0" delete="0" edit="0"
                    default_group_by="partner_id"
                    default_scale="week"
                    color="color"
                    string="Lịch giao hàng">
                <field name="bill_number"/>
                <field name="partner_id"/>
                <field name="state"/>
            </gantt>
        </field>
    </record>


    <record id="action_delivery_schedule" model="ir.actions.act_window">
        <field name="name">Lịch giao hàng</field>
        <field name="res_model">delivery.schedule</field>
        <field name="view_mode">list,form,gantt,calendar</field>
    </record>

    <menuitem id="menu_delivery_schedule"
              name="Lịch giao hàng"
              parent="purchase.menu_procurement_management"
              action="action_delivery_schedule"
              sequence="50"/>


</odoo>
