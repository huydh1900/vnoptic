<odoo>
    <record id="delivery_schedule_tree_view" model="ir.ui.view">
        <field name="name">delivery.schedule.tree</field>
        <field name="model">delivery.schedule</field>
        <field name="arch" type="xml">
            <list string="Lịch giao hàng">
                <field name="bill_number"/>
                <field name="purchase_id"/>
                <field name="contract_id"/>
                <field name="partner_id"/>
                <field name="delivery_datetime"/>
                <field name="declaration_date"/>
                <field name="declaration_number"/>
                <field name="state"
                       widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'confirmed'"/>
            </list>
        </field>
    </record>

    <record id="delivery_schedule_form_view" model="ir.ui.view">
        <field name="name">delivery.schedule.form</field>
        <field name="model">delivery.schedule</field>
        <field name="arch" type="xml">
            <form string="Lịch giao hàng">
                <header>
                    <button name="action_confirmed"
                            type="object"
                            string="Xác nhận hàng về"
                            invisible="state != 'draft'"
                            class="oe_highlight"/>
                    <button name="action_create_final_landed_cost_adjustment"
                            type="object"
                            string="Chốt điều chỉnh giá vốn"
                            invisible="state != 'confirmed'"
                            class="btn-secondary"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_contract" type="object"
                                icon="fa-file-text-o"
                                string="Hợp đồng" invisible="not contract_id"/>
                        <button name="action_view_purchase_order" type="object"
                                class="oe_stat_button"
                                icon="fa-shopping-cart"
                                invisible="not purchase_id">
                            <field name="purchase_count" widget="statinfo"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="bill_number" string="Số vận đơn"/>
                        <h1>
                            <field name="bill_number"/>
                        </h1>
                    </div>

                    <group>
                        <group name="delivery_info" string="Thông tin vận chuyển">
                            <field name="contract_id"
                                   options="{'no_create': True}"
                                   readonly="state != 'draft'"/>
                            <field name="partner_id"
                                   domain="[('supplier_rank','>',0)]" options="{'no_create': True}"
                                   readonly="context.get('from_purchase')"/>
                            <field name="partner_ref"/>
                            <field name="delivery_datetime"/>
                            <field name="description" placeholder="Nhập ghi chú nội bộ hoặc hướng dẫn giao hàng..."/>
                        </group>
                        <group name="customs_info" string="Thông tin Hải quan">
                            <field name="declaration_number"/>
                            <field name="declaration_date"/>
                            <field name="total_declaration_amount"/>
                        </group>
                        <group name="transport_info" string="Thời gian &amp; vận chuyển thực tế">
                            <field name="incoterm_id" options="{'no_create': True}"/>
                            <field name="port_loading"/>
                            <field name="port_discharge"/>
                            <field name="etd"/>
                            <field name="eta"/>
                            <field name="shipment_type"/>
                        </group>
                    </group>
                    <group string="Chi phí dự tính">
                        <group>
                            <field name="freight_est"/>
                            <field name="insurance_est"/>
                            <field name="duty_est"/>
                        </group>
                        <group>
                            <field name="tax_est"/>
                            <field name="other_cost_est"/>
                            <field name="provisional_landed_cost_total" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Chi tiết hàng giao">
	                            <field name="line_ids" force_save="1">
	                                <list editable="bottom">
	                                    <field name="contract_line_id" optional="hide" force_save="1"/>
	                                    <field name="purchase_offer_id" readonly="1"/>
	                                    <field name="product_id" readonly="1"/>
	                                    <field name="uom_id" readonly="1" optional="hide"/>
	                                    <field name="currency_id" column_invisible="1"/>
	                                    <field name="qty_contract" readonly="1" sum="Tổng SL hợp đồng"/>
	                                    <field name="qty_planned" sum="Tổng SL dự kiến"/>
	                                    <field name="qty_received" readonly="1" optional="show" sum="Tổng SL đã nhận"/>
	                                    <field name="price_unit" readonly="1" widget="monetary"/>
	                                </list>
	                            </field>
	                        </page>
                        <page string="Chi phí thực tế và Phí bổ sung">
                            <field name="extra_cost_line_ids">
                                <list editable="bottom">
                                    <field name="product_id"
                                           context="{'default_landed_cost_ok': True, 'default_type': 'service'}"
                                           domain="[('landed_cost_ok', '=', True)]"
                                           required="1"/>
                                    <field name="split_method"/>
                                    <field name="amount" string="Thực tế" widget="monetary"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="note"/>
                                </list>
                            </field>
                            <group>
                                <field name="final_landed_cost_total" readonly="1"/>
                            </group>
                        </page>
                        <page string="Thông tin bổ sung">
                            <group>
                                <field name="create_date" readonly="1"/>
                            </group>
                        </page>
                    </notebook>

                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="delivery_schedule_view_calendar" model="ir.ui.view">
        <field name="name">delivery.schedule.view.calendar</field>
        <field name="model">delivery.schedule</field>
        <field name="arch" type="xml">
            <calendar date_start="delivery_datetime" color="state">
                <field name="bill_number"/>
                <field name="partner_id"/>
            </calendar>
        </field>
    </record>

    <record id="delivery_schedule_view_gantt" model="ir.ui.view">
        <field name="name">delivery.schedule.view.gantt</field>
        <field name="model">delivery.schedule</field>
        <field name="arch" type="xml">
            <gantt
                    date_start="delivery_datetime"
                    date_stop="delivery_datetime"
                    create="0" delete="0" edit="0"
                    default_group_by="partner_id"
                    default_scale="week"
                    color="color"
                    string="Lịch giao hàng">
                <field name="bill_number"/>
                <field name="partner_id"/>
                <field name="state"/>
            </gantt>
        </field>
    </record>


    <record id="action_delivery_schedule" model="ir.actions.act_window">
        <field name="name">Lịch giao hàng</field>
        <field name="res_model">delivery.schedule</field>
        <field name="view_mode">list,form,gantt,calendar</field>
    </record>

    <menuitem id="menu_delivery_schedule"
              name="Lịch giao hàng"
              parent="purchase.menu_procurement_management"
              action="action_delivery_schedule"
              sequence="3"/>


</odoo>
