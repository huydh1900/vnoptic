<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- stock.otk.check.line inline form -->
    <record id="view_stock_otk_check_line_list" model="ir.ui.view">
        <field name="name">stock.otk.check.line.list</field>
        <field name="model">stock.otk.check.line</field>
        <field name="arch" type="xml">
            <list editable="bottom" create="0" delete="0">
                <field name="product_id"/>
                <field name="uom_id" optional="hide"/>
                <field name="qty_ordered"/>
                <field name="qty_checked_prev"/>
                <field name="qty_to_check"/>
                <field name="qty_ng" class="text-danger"/>
                <field name="qty_ok" class="text-success" readonly="1"/>
            </list>
        </field>
    </record>

    <!-- stock.otk.check list -->
    <record id="view_stock_otk_check_list" model="ir.ui.view">
        <field name="name">stock.otk.check.list</field>
        <field name="model">stock.otk.check</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" string="Lần"/>
                <field name="name"/>
                <field name="date"/>
                <field name="user_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- stock.otk.check form -->
    <record id="view_stock_otk_check_form" model="ir.ui.view">
        <field name="name">stock.otk.check.form</field>
        <field name="model">stock.otk.check</field>
        <field name="arch" type="xml">
            <form string="Lần QC">
                <header>
                    <button name="action_confirm" string="Xác nhận" type="object"
                            class="btn-primary" invisible="state != 'draft'"
                            confirm="Xác nhận lần QC này? Hàng đạt vào kho chính, hàng lỗi vào Kho Lỗi."/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="date"/>
                        <field name="user_id"/>
                    </group>
                    <field name="line_ids"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- stock.otk list -->
    <record id="view_stock_otk_list" model="ir.ui.view">
        <field name="name">stock.otk.list</field>
        <field name="model">stock.otk</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="picking_id"/>
                <field name="date"/>
                <field name="user_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- stock.otk form -->
    <record id="view_stock_otk_form" model="ir.ui.view">
        <field name="name">stock.otk.form</field>
        <field name="model">stock.otk</field>
        <field name="arch" type="xml">
            <form string="OTK">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,partial,done"/>
                    <button name="action_new_check" string="Tạo OTK" type="object"
                                class="btn-primary" invisible="state == 'done'"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_checks" type="object" class="oe_stat_button" icon="fa-search">
                            <field name="check_count" widget="statinfo" string="Lần OTK"/>
                        </button>

                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="picking_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="user_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Tổng hợp">
                            <field name="line_ids" readonly="1">
                                <list>
                                    <field name="product_id"/>
                                    <field name="uom_id"/>
                                    <field name="qty_received"/>
                                    <field name="qty_checked"/>
                                    <field name="qty_ok" class="text-success"/>
                                    <field name="qty_ng" class="text-danger"/>
                                    <field name="qty_remaining"/>
                                </list>
                            </field>
                        </page>
                        <page string="Phiếu kho">
                            <field name="ok_picking_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="state"/>
                                </list>
                            </field>
                            <field name="ng_picking_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
</odoo>
