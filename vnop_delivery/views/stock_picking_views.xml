<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="vnop_stock_picking_form_delivery_inherit" model="ir.ui.view">
        <field name="name">vnop.stock.picking.form.delivery.inherit</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="is_temp_location" invisible="1"/>
                <button name="action_otk" type="object" string="OTK"
                        class="btn-primary"
                        invisible="state not in ('assigned') or not is_temp_location"/>
            </xpath>
            <xpath expr="//button[@name='button_validate']" position="attributes">
                <attribute name="invisible">is_temp_location</attribute>
            </xpath>
        </field>
    </record>
</odoo>
