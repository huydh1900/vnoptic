<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="vnop_stock_picking_form_delivery_inherit" model="ir.ui.view">
        <field name="name">vnop.stock.picking.form.delivery.inherit</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="is_temp_location" invisible="1"/>
                <button name="action_otk" type="object" string="OTK"
                        class="btn-primary"
                        invisible="state not in ('assigned') or not is_temp_location"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_otk_transfer_ok" type="object"
                        class="oe_stat_button" icon="fa-check-circle"
                        invisible="otk_transfer_ok_count == 0">
                    <field name="otk_transfer_ok_count" string="Kho đạt" widget="statinfo"/>
                </button>
                <button name="action_view_otk_transfer_ng" type="object"
                        class="oe_stat_button" icon="fa-exclamation-triangle"
                        invisible="otk_transfer_ng_count == 0">
                    <field name="otk_transfer_ng_count" string="Kho lỗi" widget="statinfo"/>
                </button>
            </xpath>
            <xpath expr="//button[@name='button_validate']" position="attributes">
                <attribute name="invisible">is_temp_location or state in ('done', 'cancel')</attribute>
            </xpath>
            <xpath expr="//button[@name='%(stock.act_stock_return_picking)d']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='do_print_picking']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>
