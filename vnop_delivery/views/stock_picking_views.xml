<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="vnop_stock_picking_form_delivery_inherit" model="ir.ui.view">
        <field name="name">vnop.stock.picking.form.delivery.inherit</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="is_temp_location" invisible="1"/>
                <field name="otk_count" invisible="1"/>
                <button name="action_create_otk" type="object" string="Tạo phiếu OTK"
                        class="btn-primary"
                        invisible="state != 'done' or not is_temp_location or otk_count != 0"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_otk" type="object" class="oe_stat_button" icon="fa-file-text-o"
                        invisible="otk_count == 0">
                    <field name="otk_count" widget="statinfo" string="Phiếu tổng hợp OTK"/>
                </button>
            </xpath>

        </field>
    </record>
</odoo>
