<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="vnop_sync.ImportActionQueueTabs" t-inherit="ImportAction" t-inherit-mode="extension">
        <xpath expr="//ImportDataContent" position="replace">
            <div class="o_vnop_import_content_tabs d-flex flex-column flex-grow-1 overflow-auto">
                <div class="d-flex align-items-center gap-2 px-3 pt-2 border-bottom">
                    <button type="button"
                            t-att-class="'btn btn-sm ' + (this.state.activeTab === 'mapping' ? 'btn-primary' : 'btn-outline-secondary')"
                            t-on-click="() => this.switchImportTab('mapping')">
                        Du lieu import
                    </button>
                    <button t-if="this.showHistoryTab"
                            type="button"
                            t-att-class="'btn btn-sm ' + (this.state.activeTab === 'history' ? 'btn-primary' : 'btn-outline-secondary')"
                            t-on-click="() => this.switchImportTab('history')">
                        Lich su import
                    </button>
                </div>
                <div class="flex-grow-1 overflow-auto">
                    <ImportDataContent t-if="this.state.activeTab !== 'history'"
                        columns="model.columns"
                        onFieldChanged.bind="onFieldChanged"
                        onOptionChanged.bind="onOptionChanged"
                        options="importOptions"
                        isFieldSet.bind="isFieldSet"
                        previewError="state.previewError"
                        importMessages="model.importMessages"
                    />
                    <VnopImportHistoryPanel t-else=""/>
                </div>
            </div>
        </xpath>
    </t>

    <t t-name="vnop_sync.ImportQueueHistoryPanel">
        <div class="p-3">
            <div class="d-flex align-items-center justify-content-between mb-2">
                <h5 class="mb-0">Lich su import nen</h5>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary" t-on-click="reload">
                        Lam moi
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-primary" t-on-click="openList">
                        Xem tat ca
                    </button>
                </div>
            </div>

            <t t-if="state.loading">
                <div class="text-muted">Dang tai du lieu...</div>
            </t>
            <t t-elif="state.error">
                <div class="alert alert-danger" role="alert">
                    <t t-esc="state.error"/>
                </div>
            </t>
            <t t-elif="!state.records.length">
                <div class="alert alert-info" role="alert">Chua co lich su import.</div>
            </t>
            <t t-else="">
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle">
                        <thead>
                            <tr>
                                <th>File</th>
                                <th>Trang thai</th>
                                <th>Tien do</th>
                                <th>Thanh cong</th>
                                <th>Loi</th>
                                <th>Thoi gian tao</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="state.records" t-as="rec" t-key="rec.id">
                                <td>
                                    <button type="button" class="btn btn-link p-0" t-on-click="() => this.openRecord(rec.id)">
                                        <t t-esc="rec.file_name"/>
                                    </button>
                                </td>
                                <td><t t-esc="this.getStateLabel(rec.state)"/></td>
                                <td><t t-esc="rec.processed_rows"/>/<t t-esc="rec.total_rows"/></td>
                                <td><t t-esc="rec.success_count"/></td>
                                <td><t t-esc="rec.error_count"/></td>
                                <td><t t-esc="rec.create_date"/></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </t>
        </div>
    </t>

</templates>
