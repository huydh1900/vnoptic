<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="vnop_sync.ProductKanbanButtons" t-inherit="web.KanbanView" t-inherit-mode="extension">
        <xpath expr="//button[hasclass('o-kanban-button-new')]" position="after">
            <t t-if="isProductTemplate">
                <button type="button" class="btn btn-info" t-on-click="onExportTemplate">
                    <i class="fa fa-download me-1"/>Template mẫu
                </button>
                <button type="button" class="btn btn-success" t-on-click="onImportProduct">
                    <i class="fa fa-upload me-1"/>Import
                </button>
                <select class="form-select form-select-sm ms-2 vnop-product-categ-filter"
                        style="width: auto; display: inline-block;"
                        t-on-change="onCategFilterChange">
                    <option value="">Tất cả</option>
                    <option value="frame">Gọng kính</option>
                    <option value="lens">Tròng kính</option>
                    <option value="accessory">Phụ kiện</option>
                    <option value="other">Khác</option>
                </select>
            </t>
        </xpath>
    </t>

</templates>
