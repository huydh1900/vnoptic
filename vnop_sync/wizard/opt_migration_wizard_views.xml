<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Form view for opt migration wizard -->
    <record id="opt_migration_wizard_view_form" model="ir.ui.view">
        <field name="name">opt.migration.wizard.form</field>
        <field name="model">opt.migration.wizard</field>
        <field name="arch" type="xml">
            <form string="Migrate Gọng Data → Template Fields (Hướng B)">
                <sheet>
                    <div class="oe_title">
                        <h2>Migrate Dữ liệu Gọng → Fields Trên Template</h2>
                    </div>

                    <group invisible="state == 'done'">
                        <group string="Phạm vi migrate">
                            <field name="migrate_all"/>
                            <field name="product_ids"
                                   widget="many2many_tags"
                                   invisible="migrate_all"
                                   options="{'no_create': True}"/>
                        </group>
                        <group string="Tuỳ chọn">
                            <field name="delete_opt_after"/>
                        </group>
                    </group>

                    <!-- Mô tả -->
                    <div invisible="state == 'done'" class="alert alert-info" role="alert">
                        <strong>Wizard này sẽ làm gì?</strong>
                        <ul>
                            <li>Đọc từng <b>product.template</b> gọng còn dữ liệu <b>product.opt</b> cũ.</li>
                            <li>Lấy bản ghi <b>product.opt đầu tiên</b> và copy sang các field mới trên template:
                                <em>opt_season, opt_model, opt_serial, opt_frame_id, opt_materials_front_ids, opt_coating_ids, ...</em>
                            </li>
                            <li>Tùy chọn: xóa product.opt records sau khi migrate xong.</li>
                        </ul>
                        <strong>Sau migrate:</strong> Dữ liệu hiển thị trong các tab
                        <em>"Thông tin Gọng"</em>, <em>"Thiết kế Gọng"</em>, <em>"Chất liệu Gọng"</em>,
                        <em>"Màu sắc Gọng"</em>, <em>"Kích thước Gọng"</em>.
                        Tab <em>"⚠ Dữ liệu Cũ"</em> sẽ ẩn khi opt_ids rỗng.
                    </div>

                    <!-- Kết quả -->
                    <group invisible="state != 'done'" string="Kết quả">
                        <field name="result_summary" nolabel="1"
                               widget="text"
                               readonly="1"
                               style="font-family: monospace; white-space: pre;"/>
                    </group>

                </sheet>
                <footer>
                    <button name="action_migrate"
                            string="🚀 Bắt đầu Migrate"
                            type="object"
                            class="btn-primary"
                            invisible="state == 'done'"/>
                    <button string="Đóng" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Menu action để mở wizard -->
    <record id="action_opt_migration_wizard" model="ir.actions.act_window">
        <field name="name">Migrate Opt Data → Template Fields</field>
        <field name="res_model">opt.migration.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_opt_variant_migration"
              name="Migrate Gọng Data → Fields"
              parent="vnop_sync.menu_lens_migration_tools"
              action="action_opt_migration_wizard"
              sequence="20"/>

</odoo>
