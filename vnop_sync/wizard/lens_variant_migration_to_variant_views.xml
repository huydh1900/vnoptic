<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="lens_variant_migration_to_variant_wizard_view_form" model="ir.ui.view">
        <field name="name">lens.variant.migration.to.variant.wizard.form</field>
        <field name="model">lens.variant.migration.to.variant.wizard</field>
        <field name="arch" type="xml">
            <form string="Migrate Lens Data → Variants (SPH/CYL/ADD)">
                <sheet>
                    <div class="oe_title">
                        <h2>Migrate Dữ liệu Tròng → Variants</h2>
                    </div>

                    <group invisible="state == 'done'">
                        <group string="Phạm vi migrate">
                            <field name="migrate_all"/>
                            <field name="product_ids"
                                   widget="many2many_tags"
                                   invisible="migrate_all"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>

                    <div invisible="state == 'done'" class="alert alert-info" role="alert">
                        <strong>Wizard này sẽ làm gì?</strong>
                        <ul>
                            <li>Tạo variant theo SPH/CYL (và ADD nếu có).</li>
                            <li>Không generate full matrix.</li>
                            <li>Giữ nguyên dữ liệu cũ (product.lens, lens_* trên template).</li>
                        </ul>
                    </div>

                    <group invisible="state != 'done'" string="Kết quả">
                        <field name="result_summary" nolabel="1"
                               widget="text"
                               readonly="1"
                               style="font-family: monospace; white-space: pre;"/>
                    </group>

                </sheet>
                <footer>
                    <button name="action_migrate"
                            string="🚀 Bắt đầu Migrate"
                            type="object"
                            class="btn-primary"
                            invisible="state == 'done'"/>
                    <button string="Đóng" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_lens_variant_migration_to_variant_wizard" model="ir.actions.act_window">
        <field name="name">Migrate Lens Data → Variants</field>
        <field name="res_model">lens.variant.migration.to.variant.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_lens_variant_migration_to_variant"
              name="Migrate Lens Data → Variants"
              parent="menu_lens_migration_tools"
              action="action_lens_variant_migration_to_variant_wizard"
              sequence="20"/>

</odoo>
