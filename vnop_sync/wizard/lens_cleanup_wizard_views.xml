<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ════════════════════════════════════════════════════════════════════
         Action mở wizard từ menu Cấu hình
         ════════════════════════════════════════════════════════════════════ -->
    <record id="action_lens_cleanup_wizard" model="ir.actions.act_window">
        <field name="name">Chuẩn hóa Lens – Xóa Variant &amp; Attribute</field>
        <field name="res_model">lens.cleanup.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chạy wizard để chuẩn hóa lens (Phần 1)
            </p>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════════
         Form view wizard
         ════════════════════════════════════════════════════════════════════ -->
    <record id="lens_cleanup_wizard_form_view" model="ir.ui.view">
        <field name="name">lens.cleanup.wizard.form</field>
        <field name="model">lens.cleanup.wizard</field>
        <field name="arch" type="xml">
            <form string="Chuẩn hóa Lens – Xóa Variant &amp; Attribute SPH/CYL/ADD">
                <sheet>
                    <div class="alert alert-info" role="alert" invisible="state != 'draft'">
                        <strong>📋 Mục tiêu wizard này:</strong>
                        <ul>
                            <li>Tìm tất cả <b>product.template</b> có <code>product_type = 'lens'</code></li>
                            <li>Xóa toàn bộ <code>attribute_line_ids</code> (SPH/CYL/ADD)</li>
                            <li>Xóa variant dư, chỉ giữ <b>1 default variant</b> mỗi template</li>
                            <li>Báo cáo chi tiết số liệu đã cleanup</li>
                        </ul>
                        <strong>⚠️ Không ảnh hưởng gọng kính, không xóa dữ liệu nghiệp vụ khác.</strong>
                    </div>

                    <div class="alert alert-success" role="alert" invisible="state != 'done'">
                        <strong>✅ Cleanup hoàn thành!</strong> Xem kết quả bên dưới.
                    </div>

                    <group string="Tuỳ chọn cleanup" invisible="state != 'draft'">
                        <field name="also_remove_sph_cyl_add_attrs"
                               string="Xóa global attribute SPH/CYL/ADD (sau khi xóa khỏi lens templates)"/>
                    </group>

                    <group string="Kết quả" invisible="state != 'done'">
                        <group>
                            <field name="lens_count" string="Lens templates đã xử lý"/>
                            <field name="attr_removed" string="Attribute lines đã xóa"/>
                            <field name="variant_removed" string="Variant dư đã xóa"/>
                        </group>
                        <group>
                            <field name="design_created" string="Design mới tạo (thông tin)"/>
                            <field name="material_created" string="Material mới tạo (thông tin)"/>
                        </group>
                    </group>

                    <group string="Nhật ký" invisible="state != 'done'">
                        <field name="log_text" nolabel="1" readonly="1"
                               widget="text" style="font-family: monospace; font-size: 12px;"/>
                    </group>
                </sheet>

                <footer>
                    <button name="action_count_stats"
                            string="📊 Đếm thống kê (Dry-run)"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'draft'"/>
                    <button name="action_run_cleanup"
                            string="🚀 Chạy Cleanup Ngay"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button string="Đóng"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════════
         Menu item trong Cấu hình
         ════════════════════════════════════════════════════════════════════ -->
    <menuitem id="menu_lens_cleanup_wizard"
              name="Chuẩn hóa Lens (Cleanup Variant)"
              parent="product.product_category_action_form"
              action="action_lens_cleanup_wizard"
              sequence="99"/>
</odoo>
