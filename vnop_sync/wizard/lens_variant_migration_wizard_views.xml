<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Form view for migration wizard -->
    <record id="lens_variant_migration_wizard_view_form" model="ir.ui.view">
        <field name="name">lens.variant.migration.wizard.form</field>
        <field name="model">lens.variant.migration.wizard</field>
        <field name="arch" type="xml">
            <form string="Migrate Lens Data → Template Fields (Hướng B)">
                <sheet>
                    <div class="oe_title">
                        <h2>Migrate Dữ liệu Tròng → Fields Trên Template</h2>
                    </div>

                    <group invisible="state == 'done'">
                        <group string="Phạm vi migrate">
                            <field name="migrate_all"/>
                            <field name="product_ids"
                                   widget="many2many_tags"
                                   invisible="migrate_all"
                                   options="{'no_create': True}"/>
                        </group>
                        <group string="Tuỳ chọn">
                            <field name="delete_lens_after"/>
                        </group>
                    </group>

                    <!-- Mô tả -->
                    <div invisible="state == 'done'" class="alert alert-info" role="alert">
                        <strong>Wizard này sẽ làm gì?</strong>
                        <ul>
                            <li>Đọc từng <b>product.template</b> lens còn dữ liệu <b>product.lens</b> cũ.</li>
                            <li>Lấy bản ghi <b>product.lens đầu tiên</b> và copy sang các field mới trên template:
                                <em>lens_sph_id, lens_cyl_id, lens_add, lens_material_id, lens_index_id, lens_uv_id, lens_coating_ids, ...</em>
                            </li>
                            <li>Tùy chọn: xóa product.lens records sau khi migrate xong.</li>
                        </ul>
                        <strong>Sau migrate:</strong> Dữ liệu hiển thị trong tab
                        <em>"Thiết kế Tròng"</em>, <em>"Chất liệu Tròng"</em>, <em>"Tích hợp Tròng"</em>.
                        Tab <em>"Dữ liệu Cũ"</em> sẽ ẩn khi lens_ids rỗng.
                    </div>

                    <!-- Kết quả -->
                    <group invisible="state != 'done'" string="Kết quả">
                        <field name="result_summary" nolabel="1"
                               widget="text"
                               readonly="1"
                               style="font-family: monospace; white-space: pre;"/>
                    </group>

                </sheet>
                <footer>
                    <button name="action_migrate"
                            string="🚀 Bắt đầu Migrate"
                            type="object"
                            class="btn-primary"
                            invisible="state == 'done'"/>
                    <button string="Đóng" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Menu action để mở wizard -->
    <record id="action_lens_variant_migration_wizard" model="ir.actions.act_window">
        <field name="name">Migrate Lens Data → Template Fields</field>
        <field name="res_model">lens.variant.migration.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Thêm vào menu "Đồng bộ sản phẩm > Công cụ" -->
    <menuitem id="menu_lens_migration_tools"
              name="Công cụ"
              parent="vnop_sync.menu_product_sync_root"
              sequence="30"/>

    <menuitem id="menu_lens_variant_migration"
              name="Migrate Lens Data → Fields"
              parent="menu_lens_migration_tools"
              action="action_lens_variant_migration_wizard"
              sequence="10"/>

</odoo>
