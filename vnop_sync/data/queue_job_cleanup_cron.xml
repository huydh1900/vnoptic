<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="1">
    <record id="cron_cleanup_zombie_queue_jobs" model="ir.cron">
        <field name="name">Queue Job: Cleanup zombie jobs (auto-reset stuck started)</field>
        <field name="model_id" ref="queue_job.model_queue_job"/>
        <field name="state">code</field>
        <field name="code">model.cleanup_zombie_jobs(30, 5)</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
        <field name="user_id" ref="base.user_root"/>
    </record>
</odoo>
