<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_product_sync_tree" model="ir.ui.view">
        <field name="name">product.sync.tree</field>
        <field name="model">product.sync</field>
        <field name="arch" type="xml">
            <list string="Đồng bộ sản phẩm">
                <field name="name"/>
                <field name="last_sync_date"/>
                <field name="total_synced"/>
                <field name="sync_status" widget="badge"
                       decoration-success="sync_status == 'success'"
                       decoration-danger="sync_status == 'error'"
                       decoration-muted="sync_status == 'never'"/>
            </list>
        </field>
    </record>

    <record id="view_product_sync_form" model="ir.ui.view">
        <field name="name">product.sync.form</field>
        <field name="model">product.sync</field>
        <field name="arch" type="xml">
            <form string="Đồng bộ sản phẩm">
                <header>
                    <button name="sync_products_from_springboot"
                            string="Đồng bộ toàn bộ"
                            type="object"
                            class="oe_highlight"
                            invisible="id == False"
                            confirm="Sync toàn bộ sản phẩm? Có thể mất nhiều thời gian."/>
                    <button name="sync_data_only"
                            string="Đồng bộ thông tin"
                            type="object"
                            invisible="id == False"
                            confirm="Sync thông tin sản phẩm (không sync ảnh)?"/>
                    <button name="sync_images_only"
                            string="Đồng bộ ảnh"
                            type="object"
                            invisible="id == False"
                            confirm="Chỉ sync ảnh sản phẩm?"/>
                    <button name="sync_products_limited"
                            string="Đồng bộ 200 Test"
                            type="object"
                            invisible="id == False"/>
                    <field name="sync_status" widget="statusbar" statusbar_visible="never,success,error"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Cấu hình đồng bộ"/>
                        <h1>
                            <field name="name" placeholder="vd: Đồng bộ hàng ngày"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Thống kê">
                            <field name="last_sync_date" readonly="1"/>
                            <field name="total_synced" readonly="1"/>
                            <field name="total_failed" readonly="1"/>
                        </group>
                        <group string="Số lượng">
                            <field name="lens_count" readonly="1"/>
                            <field name="opts_count" readonly="1"/>
                            <field name="other_count" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Nhật ký" name="sync_log">
                            <field name="sync_log" widget="text" placeholder="Nhật ký sẽ hiển thị ở đây..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================== ACTION ==================== -->
    <record id="action_product_sync" model="ir.actions.act_window">
        <field name="name">Product Synchronization</field>
        <field name="res_model">product.sync</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Top-level menu -->
    <menuitem id="menu_vnop_sync_root"
              name="Đồng bộ sản phẩm"
              sequence="99"
              web_icon="stock,static/description/icon.png"/>

    <menuitem id="menu_vnop_sync_product"
              name="Đồng bộ sản phẩm"
              parent="menu_vnop_sync_root"
              action="action_product_sync"
              sequence="10"/>

</odoo>
