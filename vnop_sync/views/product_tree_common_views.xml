<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_tree_view_product" model="ir.ui.view">
        <field name="name">product.template.tree.product</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <!-- Hide default_code, show barcode before name -->
            <field name="default_code" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </field>
            <xpath expr="//field[@name='name']" position="before">
                <field name="barcode"/>
            </xpath>
            <!-- Hide product_tag_ids column -->
            <field name="product_tag_ids" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </field>
            <!-- Hide is_favorite column -->
            <field name="is_favorite" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </field>
            <!-- Add common fields after name -->
            <xpath expr="//field[@name='name']" position="after">
                <!-- Common fields -->
                <field name="brand_id" optional="show"/>
                <field name="primary_supplier_id" optional="hide"/>
                <field name="country_id" optional="hide"/>
                
                <!-- Price fields -->
                <field name="x_ws_price" optional="hide"/>
                <field name="product_status" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="product_template_search_view_product" model="ir.ui.view">
        <field name="name">product.template.search.product</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <!-- Add filter for product_type after filter_to_sell -->
            <xpath expr="//filter[@name='filter_to_sell']" position="after">
                <separator/>
                <filter string="Tròng kính" name="filter_lens" domain="[('classification_type', '=', 'lens')]"/>
                <filter string="Gọng kính" name="filter_opt" domain="[('classification_type', '=', 'frame')]"/>
                <filter string="Phụ kiện" name="filter_accessory" domain="[('classification_type', '=', 'accessory')]"/>
            </xpath>
        </field>
    </record>

    <record id="product_template_search_view_product_purchase" model="ir.ui.view">
        <field name="name">product.template.search.product.purchase</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="arch" type="xml">
            <!-- Add filter for product_type after filter_to_purchase -->
            <xpath expr="//filter[@name='filter_to_purchase']" position="after">
                <separator/>
                <filter string="Tròng kính" name="filter_lens" domain="[('classification_type', '=', 'lens')]"/>
                <filter string="Gọng kính" name="filter_opt" domain="[('classification_type', '=', 'frame')]"/>
                <filter string="Phụ kiện" name="filter_accessory" domain="[('classification_type', '=', 'accessory')]"/>
            </xpath>
        </field>
    </record>

    <record id="product_template_search_view_product_stock" model="ir.ui.view">
        <field name="name">product.template.search.product.stock</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="stock.product_template_search_form_view_stock"/>
        <field name="arch" type="xml">
            <!-- Add filter for product_type after goods -->
            <xpath expr="//filter[@name='goods']" position="after">
                <separator/>
                <filter string="Tròng kính" name="filter_lens" domain="[('classification_type', '=', 'lens')]"/>
                <filter string="Gọng kính" name="filter_opt" domain="[('classification_type', '=', 'frame')]"/>
                <filter string="Phụ kiện" name="filter_accessory" domain="[('classification_type', '=', 'accessory')]"/>
            </xpath>
        </field>
    </record>
</odoo>
