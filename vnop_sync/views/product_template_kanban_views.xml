<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="product_template_kanban_view_vnop_modern" model="ir.ui.view">
        <field name="name">product.template.kanban.vnop.modern</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_kanban_view"/>
        <field name="priority">130</field>
        <field name="arch" type="xml">
            <xpath expr="//kanban" position="attributes">
                <attribute name="class" add="vnop_product_kanban" separator=" "/>
                <attribute name="group_create">0</attribute>
                <attribute name="group_delete">0</attribute>
                <attribute name="group_edit">0</attribute>
                <attribute name="quick_create">0</attribute>
                <attribute name="records_draggable">0</attribute>
            </xpath>

            <xpath expr="//kanban" position="inside">
                <field name="image_128"/>
                <field name="default_code"/>
                <field name="categ_code"/>
                <field name="brand_id"/>
                <field name="group_id"/>
                <field name="country_id"/>
                <field name="product_status"/>
                <field name="qty_available"/>
                <field name="uom_id"/>
                <field name="currency_id"/>
                <field name="list_price"/>
                <field name="x_ws_price"/>
            </xpath>

            <xpath expr="//kanban/templates" position="replace">
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click vnop_card">
                            <!-- Top row: image + info side by side -->
                            <div class="vnop_card_top">
                                <!-- Thumbnail -->
                                <div class="vnop_thumb">
                                    <t t-if="record.image_128.raw_value">
                                        <field name="image_128" widget="image"/>
                                    </t>
                                    <t t-else="">
                                        <div class="vnop_thumb_placeholder">
                                            <i class="fa fa-camera"/>
                                        </div>
                                    </t>
                                </div>

                                <!-- Main info -->
                                <div class="vnop_card_info">
                                    <!-- Badges -->
                                    <div class="vnop_badges">
                                        <span class="vnop_badge vnop_b_frame" t-if="record.categ_code.raw_value == 'GK'">Gọng</span>
                                        <span class="vnop_badge vnop_b_lens" t-if="record.categ_code.raw_value == 'TK'">Tròng</span>
                                        <span class="vnop_badge vnop_b_other"
                                              t-if="record.categ_code.raw_value &amp;&amp; !['GK', 'TK'].includes(record.categ_code.raw_value)">
                                            <t t-esc="record.categ_code.value"/>
                                        </span>
                                        <span class="vnop_badge vnop_b_status" t-if="record.product_status.raw_value">
                                            <t t-esc="record.product_status.value"/>
                                        </span>
                                    </div>

                                    <!-- Title -->
                                    <div class="vnop_title" t-att-title="record.name.value">
                                        <field name="name"/>
                                    </div>

                                    <!-- SKU -->
                                    <div class="vnop_sku">
                                        <t t-if="record.default_code.raw_value"><field name="default_code"/></t>
                                    </div>
                                </div>
                            </div>

                            <!-- Meta tags -->
                            <div class="vnop_tags">
                                <span t-if="record.brand_id.raw_value"><field name="brand_id"/></span>
                                <span t-if="record.country_id.raw_value"><field name="country_id"/></span>
                                <span t-if="record.group_id.raw_value"><field name="group_id"/></span>
                            </div>

                            <!-- Footer: stock + price -->
                            <div class="vnop_card_foot">
                                <div class="vnop_stock" t-if="record.qty_available.raw_value !== undefined">
                                    <span t-att-class="'vnop_dot ' + (record.qty_available.raw_value > 10 ? 'vnop_dot_ok' : (record.qty_available.raw_value > 0 ? 'vnop_dot_low' : 'vnop_dot_out'))"/>
                                    <field name="qty_available"/>
                                    <span class="vnop_uom" t-if="record.uom_id.raw_value"><field name="uom_id"/></span>
                                </div>
                                <div class="vnop_price">
                                    <span class="vnop_price_main"><field name="list_price" widget="monetary"/></span>
                                    <span class="vnop_price_ws" t-if="record.x_ws_price.raw_value">
                                        Sỉ <field name="x_ws_price" widget="monetary"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </xpath>
        </field>
    </record>
</odoo>
