<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- List view -->
    <record id="product_warranty_template_view_list" model="ir.ui.view">
        <field name="name">product.warranty.template.list</field>
        <field name="model">product.warranty.template</field>
        <field name="arch" type="xml">
            <list string="Chính sách bảo hành">
                <field name="name"/>
                <field name="manufacturer_months" string="NSX (tháng)"/>
                <field name="company_months" string="Công ty (tháng)"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="product_warranty_template_view_form" model="ir.ui.view">
        <field name="name">product.warranty.template.form</field>
        <field name="model">product.warranty.template</field>
        <field name="arch" type="xml">
            <form string="Chính sách bảo hành">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="manufacturer_months"/>
                            <field name="company_months"/>
                        </group>
                    </group>
                    <group string="Ghi chú">
                        <field name="note" nolabel="1" placeholder="Ghi chú thêm về chính sách bảo hành..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_product_warranty_template" model="ir.actions.act_window">
        <field name="name">Chính sách bảo hành</field>
        <field name="res_model">product.warranty.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
