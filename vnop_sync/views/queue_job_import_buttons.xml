<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_queue_job_form_vnop_import_button" model="ir.ui.view">
        <field name="name">queue.job.form.vnop.import.button</field>
        <field name="model">queue.job</field>
        <field name="inherit_id" ref="queue_job.view_queue_job_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">
                <field name="method_name" invisible="1"/>
                <button name="action_open_import_from_test_queue" type="object" class="btn-primary"
                    string="Mo giao dien nhap"
                    invisible="model_name != 'product.import.queue.session' or method_name != '_run_test_queue_job' or state != 'done'"/>
            </xpath>
        </field>
    </record>
</odoo>
