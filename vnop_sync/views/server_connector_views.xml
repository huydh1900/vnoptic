<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_server_connector_tree" model="ir.ui.view">
        <field name="name">server.connector.tree</field>
        <field name="model">server.connector</field>
        <field name="arch" type="xml">
            <list string="API Connector">
                <field name="api_url"/>
                <field name="service_username" optional="hide"/>
                <field name="last_sync_date" optional="show"/>
                <field name="last_sync_status" optional="show" widget="badge"
                       decoration-success="last_sync_status == 'success'"
                       decoration-danger="last_sync_status == 'error'"/>
            </list>
        </field>
    </record>

    <record id="view_server_connector_form" model="ir.ui.view">
        <field name="name">server.connector.form</field>
        <field name="model">server.connector</field>
        <field name="arch" type="xml">
            <form string="API Connector">
                <header>
                    <button name="test_connection" string="Test Connection"
                            type="object" class="oe_highlight"/>
                </header>
                <sheet>
                    <group>
                        <group string="API Configuration">
                            <field name="api_url"/>
                            <field name="service_username"/>
                            <field name="service_password" password="True"/>
                        </group>
                        <group string="Status">
                            <field name="last_sync_date" readonly="1"/>
                            <field name="last_sync_status" readonly="1"/>
                            <field name="last_sync_message" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_server_connector" model="ir.actions.act_window">
        <field name="name">API Connector</field>
        <field name="res_model">server.connector</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
