<odoo>
    <record id="product_export_template_wizard_form_view" model="ir.ui.view">
        <field name="name">product.export.template.wizard.form</field>
        <field name="model">product.export.template.wizard</field>
        <field name="arch" type="xml">
            <form string="Tải file mẫu sản phẩm">
                <group>
                    <field name="product_type"/>
                </group>
                <footer>
                    <button name="action_export_template" type="object" string="Tải file mẫu" class="btn-primary"/>
                    <button string="Đóng" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_product_export_template_wizard" model="ir.actions.act_window">
        <field name="name">Tải file mẫu sản phẩm</field>
        <field name="res_model">product.export.template.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="product_export_template_wizard_form_view"/>
    </record>

    <record id="action_product_export_template_wizard_server" model="ir.actions.server">
        <field name="name">Tải file mẫu import (Mắt/Gọng/Phụ kiện)</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = env['ir.actions.actions']._for_xml_id('vnop_sync.action_product_export_template_wizard')</field>
    </record>

    <menuitem id="menu_product_export_template_wizard_purchase" name="Tải file mẫu sản phẩm" parent="purchase.menu_product_in_config_purchase" action="action_product_export_template_wizard" sequence="1000"/>
    <menuitem id="menu_product_export_template_wizard_stock" name="Tải file mẫu sản phẩm" parent="stock.menu_product_in_config_stock" action="action_product_export_template_wizard" sequence="1000"/>
</odoo>
