<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_product_brand" model="ir.actions.act_window">
        <field name="name">Thương hiệu</field>
        <field name="res_model">product.brand</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_product_brand_tree" model="ir.ui.view">
        <field name="name">product.brand.tree</field>
        <field name="model">product.brand</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
            </list>
        </field>
    </record>

    <record id="view_product_brand_form" model="ir.ui.view">
        <field name="name">product.brand.form</field>
        <field name="model">product.brand</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name" placeholder="VD: Essilor, Cadillac, ZenOptic"/>
                        <field name="code" placeholder="VD: 003, 004, 005"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem id="menu_product_brand"
              name="Thương hiệu"
              parent="purchase.menu_product_in_config_purchase"
              action="action_product_brand"
              sequence="5"/>

</odoo>
