<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Default group by categ_id khi mở menu Products trong Purchase -->
    <function model="ir.actions.act_window" name="write">
        <function model="ir.actions.act_window" name="search"
                  eval="[[('id', '=', ref('purchase.product_normal_action_puchased'))]]"/>
        <value eval="{'context': {'search_default_filter_to_purchase': 1, 'purchase_product_template': 1, 'search_default_group_by_categ_id': 1}}"/>
    </function>

    <!-- Ẩn filter "Product Type" (group_by=type) trong catalog search view
         (dùng khi chọn sản phẩm trên Sale/Purchase Order). -->
    <record id="product_view_search_catalog_inherit_vnop" model="ir.ui.view">
        <field name="name">product.view.search.catalog.inherit.vnop</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_view_search_catalog"/>
        <field name="arch" type="xml">
            <filter name="type" position="replace"/>
        </field>
    </record>

    <!-- Extend product search view -->
    <record id="product_template_search_inherit_vnop" model="ir.ui.view">
        <field name="name">product.template.search.inherit.vnop</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="priority">102</field>
        <field name="arch" type="xml">
            <search>
                <!-- Xóa hẳn filter "Product Type" (group_by=type) của base Odoo
                     để tránh trùng với filter "Loại sản phẩm" (group_by categ_code)
                     do vnop_sync thêm ở dưới. -->
                <filter name="type" position="replace"/>
                <field name="name" filter_domain="['|', ('name', 'ilike', self), ('default_code', 'ilike', self)]"/>
                <field name="brand_id"/>
                <field name="categ_id"/>
                <field name="group_id"/>
                <field name="country_id"/>
                <separator/>
                <filter name="filter_lens" string="Tròng kính" domain="[('categ_code','=','TK')]"/>
                <filter name="filter_opt" string="Gọng kính" domain="[('categ_code','=','GK')]"/>
                <filter name="filter_acc" string="Phụ kiện" domain="[('categ_code','in',['PK','TB','LK'])]"/>
                <separator/>
                <filter name="filter_len_dt" string="Đơn tròng" domain="[('len_type','=','DT')]"/>
                <filter name="filter_len_ht" string="Hai tròng" domain="[('len_type','=','HT')]"/>
                <filter name="filter_len_dat" string="Đa tròng" domain="[('len_type','=','DAT')]"/>
                <filter name="filter_len_pt" string="Phôi tròng" domain="[('len_type','=','PT')]"/>
                <separator/>
                <filter name="filter_active" string="Đang hoạt động" domain="[('active','=',True)]"/>
                <group expand="0" string="Nhóm theo">
                    <filter name="group_by_product_type" string="Loại sản phẩm" context="{'group_by': 'categ_code'}"/>
                    <filter name="group_by_len_type" string="Loại tròng" context="{'group_by': 'len_type'}"/>
                    <filter name="group_by_categ_id" string="Danh mục" context="{'group_by': 'categ_id'}"/>
                    <filter name="group_by_brand" string="Thương hiệu" context="{'group_by': 'brand_id'}"/>
                    <filter name="group_by_group" string="Nhóm sản phẩm" context="{'group_by': 'group_id'}"/>
                    <filter name="group_by_country" string="Xuất xứ" context="{'group_by': 'country_id'}"/>
                </group>
            </search>
        </field>
    </record>


    <record id="product_template_form_inherit_product" model="ir.ui.view">
        <field name="name">product.template.form.inherit.product</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='image_1920']" position="replace">
                <field name="image_1920" widget="image" class="oe_avatar"
                       options="{'convert_to_webp': True, 'preview_image': 'image_128'}"/>
                <field name="qr_code" widget="image" nolabel="1" readonly="1"
                       invisible="type != 'consu' or not qr_code"
                       options="{'size': [100, 100]}"
                       class="oe_avatar"
                       style="margin-right:15px;"/>
            </xpath>

            <!-- Ẩn field base trong group_standard_price khi là hàng hóa (consu) -->
            <xpath expr="//group[@name='group_standard_price']/field[@name='categ_id']" position="attributes">
                <attribute name="invisible">type == 'consu'</attribute>
            </xpath>
            <xpath expr="//group[@name='group_standard_price']/field[@name='default_code']" position="attributes">
                <attribute name="invisible" add="type == 'consu'" separator=" or "/>
            </xpath>

            <xpath expr="//page[@name='general_information']//group[@name='internal_notes']" position="attributes">
                <attribute name="string">Mô tả</attribute>
            </xpath>

            <!-- Ẩn tab Thuộc tính & Biến thể cho tròng và gọng kính -->
            <xpath expr="//page[.//field[@name='attribute_line_ids']]" position="attributes">
                <attribute name="invisible">categ_code in ('TK', 'GK')</attribute>
            </xpath>

            <!-- Removed product_type selection from header -->

            <!-- Add Giá & Bảo hành into Sales tab (not general_information) -->
            <xpath expr="//page[@name='sales']" position="inside">
                <group string="Thông tin giá" invisible="type != 'consu'">
                    <group>
                        <field name="x_ws_price"/>
                        <field name="x_ws_price_min"/>
                        <field name="x_ws_price_max"/>
                        <field name="gia_si_theo_phan_tram"/>
                    </group>
                </group>
            </xpath>

            <!-- Add Product General Info Section -->
            <xpath expr="//sheet/notebook/page[@name='general_information']/group" position="before">
                <!-- ── Thông tin chung ── -->
                <group string="Thông tin chung" invisible="type != 'consu'">
                    <group>
                        <field name="default_code"/>
                        <field name="categ_id" options="{'no_create': True}"/>
                        <field name="len_type" invisible="categ_code != 'TK'"/>
                        <field name="group_id"
                               domain="['&amp;', ('category_id', 'child_of', categ_id), '|', ('category_id.code', '!=', 'TK'), ('product_type', '=', len_type)]"
                               options="{'no_create': True}"/>
                        <field name="brand_id"/>
                        <field name="primary_supplier_id" readonly="1"/>
                        <field name="country_id" options="{'no_create': True}"/>
                        <field name="uom_id" options="{'no_create': True}"/>
                        <field name="index_id" options="{'no_create': True}" invisible="1"/>
                    </group>
                    <group>
                        <field name="product_status"/>
                        <field name="x_eng_name"/>
                        <field name="warranty_id" options="{'no_create': True}"/>
                        <field name="warranty_supplier_id" options="{'no_create': True}"/>
                        <field name="warranty_retail_id" options="{'no_create': True}"/>
                    </group>
                </group>

                <!-- ── Thiết kế Tròng (chỉ hiện khi danh mục thuộc Tròng kính) ── -->
                <group string="Thiết kế Tròng" invisible="type != 'consu' or categ_code != 'TK'">
                    <group>
                        <field name="lens_sph_id" options="{'no_create': False}"/>
                        <field name="lens_cyl_id" options="{'no_create': False}"/>
                        <field name="lens_add_id" options="{'no_create': False}"/>
                        <field name="x_axis"/>
                        <field name="x_diameter"/>
                    </group>
                    <group>
                        <field name="lens_design1_id" options="{'no_create': False}"/>
                        <field name="lens_design2_id" options="{'no_create': False}"/>
                        <field name="x_prism"/>
                        <field name="x_prism_base"/>
                    </group>
                </group>

                <!-- ── Chất liệu &amp; Tích hợp Tròng (chỉ hiện khi danh mục thuộc Tròng kính) ── -->
                <group string="Chất liệu &amp; Tích hợp" invisible="type != 'consu' or categ_code != 'TK'">
                    <group>
                        <field name="lens_material_id" options="{'no_create': False}"/>
                        <field name="lens_index_id" options="{'no_create': False}"/>
                        <field name="lens_uv_id" options="{'no_create': False}"/>
                        <field name="lens_coating_ids" widget="many2many_tags"
                               options="{'no_create': False}"/>
                    </group>
                    <group>
                        <field name="lens_cl_hmc_id" options="{'no_create': False}"/>
                        <field name="lens_cl_pho_id" options="{'no_create': False}"/>
                        <field name="lens_cl_tint_id" options="{'no_create': False}"/>
                    </group>
                </group>
            </xpath>

            <!-- Add custom tabs to notebook -->
            <xpath expr="//notebook" position="inside">

                <!-- ══════════════════════════════════════════════════════════
                     Tabs Lens (Hướng B: field trực tiếp trên template)
                     Hiển thị chỉ khi product_type = 'lens'
                     ══════════════════════════════════════════════════════════ -->

                <!-- Tab Legacy: product.lens cũ (chỉ hiện khi còn dữ liệu chưa migrate) -->
                <page string="⚠ Dữ liệu Cũ (product.lens)" name="product_lens_legacy"
                      invisible="type != 'consu' or categ_code != 'TK' or not lens_ids">
                    <div class="alert alert-warning" role="alert">
                        <strong>⚠️ Dữ liệu Legacy:</strong>
                        Tab này hiển thị dữ liệu cũ từ model <em>product.lens</em>.
                        Hãy chạy wizard <b>Migrate Lens Data → Fields</b> (menu Cấu hình) để chuyển
                        sang các field mới ở tab <b>"Thiết kế Tròng"</b> / <b>"Chất liệu Tròng"</b> / <b>"Tích hợp
                        Tròng"</b>.
                    </div>
                    <field name="lens_ids" nolabel="1">
                        <list create="0" delete="0">
                            <field name="sph_id" readonly="1"/>
                            <field name="cyl_id" readonly="1"/>
                            <field name="lens_add" readonly="1"/>
                            <field name="diameter" readonly="1"/>
                            <field name="material_id" readonly="1"/>
                            <field name="index_id" readonly="1"/>
                            <field name="uv_id" readonly="1"/>
                            <field name="coating_ids" widget="many2many_tags" readonly="1"/>
                        </list>
                    </field>
                </page>

                <!-- ══════════════════════════════════════════════════════════
                     Tabs Gọng (Hướng B: field trực tiếp trên template)
                     Hiển thị chỉ khi danh mục thuộc Gọng kính
                     ══════════════════════════════════════════════════════════ -->

                <!-- Tab Gọng: gộp Thông tin / Thiết kế / Vật liệu / Màu sắc & Kích thước -->
                <page string="Thông tin chi tiết" name="product_opt_detail"
                      invisible="type != 'consu' or categ_code != 'GK'">
                    <group string="Thông tin chung">
                        <group>
                            <field name="opt_season"/>
                            <field name="opt_model"/>
                            <field name="opt_serial"/>
                            <field name="opt_sku"/>
                        </group>
                        <group>
                            <field name="opt_color"/>
                            <field name="opt_oem_ncc"/>
                        </group>
                    </group>

                    <group string="Thiết kế">
                        <group>
                            <field name="opt_frame_id" options="{'no_create': True}"/>
                            <field name="opt_frame_type_id" options="{'no_create': True}"/>
                            <field name="opt_shape_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="opt_ve_id" options="{'no_create': True}"/>
                            <field name="opt_temple_id" options="{'no_create': True}"/>
                            <field name="opt_gender"/>
                        </group>
                    </group>

                    <group string="Vật liệu">
                        <group>
                            <field name="opt_materials_front_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                            <field name="opt_materials_temple_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                            <field name="opt_material_temple_tip_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="opt_material_lens_id" options="{'no_create': True}"/>
                            <field name="opt_material_ve_id" options="{'no_create': True}"/>
                            <field name="opt_coating_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>

                    <group string="Màu sắc và kích thước">
                        <group string="Màu sắc">
                            <group>
                                <field name="opt_color_front_ids"
                                       widget="many2many_tags" options="{'no_create': True}"/>
                                <field name="opt_color_temple_ids"
                                       widget="many2many_tags" options="{'no_create': True}"/>
                                <field name="opt_color_lens_id"
                                       options="{'no_create': True}"/>
                            </group>
                        </group>
                        <group string="Kích thước (mm)">
                            <group>
                                <field name="opt_temple_width"/>
                                <field name="opt_lens_width"/>
                                <field name="opt_bridge_width"/>
                            </group>
                            <group>
                                <field name="opt_lens_height"/>
                                <field name="opt_lens_span"/>
                            </group>
                        </group>
                    </group>
                </page>

                <!-- Tab Gọng 6: Bảo hành -->
                <page string="Bảo hành Gọng" name="product_opt_warranty"
                      invisible="1">
                    <group string="Chính sách bảo hành">
                        <group>
                        </group>
                        <group>
                            <field name="manufacturer_months"/>
                            <field name="company_months"/>
                            <field name="bao_hanh_ban_le"/>
                        </group>
                    </group>
                </page>

                <!-- Tab Gọng 7: Phụ kiện đi kèm -->
                <page string="Phụ kiện đi kèm" name="product_opt_accessories"
                      invisible="type != 'consu' or categ_code != 'GK'">
                    <group string="Phụ kiện">
                        <group>
                            <field name="has_box"/>
                            <field name="has_cleaning_cloth"/>
                            <field name="has_warranty_card"/>
                        </group>
                    </group>
                    <group string="Ghi chú">
                        <field name="accessory_note" nolabel="1"
                               placeholder="Ghi chú thêm về phụ kiện..."/>
                    </group>
                </page>

                <!-- Tabs Phụ kiện / Sản phẩm khác (không phải lens/opt) -->
                <page string="Thông tin chi tiết" name="accessory_detail"
                      invisible="type != 'consu' or categ_code in ('TK', 'GK', 'LK')">
                    <group string="Thiết kế">
                        <group>
                            <field name="design_id"/>
                            <field name="shape_id"/>
                        </group>
                    </group>
                    <group string="Vật liệu &amp; Màu sắc">
                        <group>
                            <field name="material_id"/>
                            <field name="color_id"/>
                        </group>
                    </group>
                    <group string="Kích thước">
                        <group>
                            <field name="acc_width"/>
                            <field name="acc_length"/>
                            <field name="acc_height"/>
                            <field name="acc_head"/>
                            <field name="acc_body"/>
                        </group>
                    </group>
                </page>

            </xpath>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════
         CUSTOM INHERIT: fix view product (lens)
         1. default_code label → "Mã viết tắt"
         2. Ẩn index_id (trùng với lens_index_id)
         3. Thêm country_id vào tab Thông tin chung
         4. Đổi label price → "Giá nguyên tệ" trong tab Mua hàng
         5. Ẩn don_vi_nguyen_te khỏi view
         ══════════════════════════════════════════════════════════ -->

    <!-- country_id đã được thêm trực tiếp vào group "Phân loại sản phẩm" trong view product_template_form_inherit_product -->
    <!-- default_code label đổi trực tiếp trong view product_template_form_inherit_product bằng xpath -->

    <!-- 4. Đổi label cột "price" → "Giá nguyên tệ" trong bảng NCC (tab Mua hàng) -->
    <record id="view_product_supplierinfo_price_custom" model="ir.ui.view">
        <field name="name">product.supplierinfo.list.price.custom</field>
        <field name="model">product.supplierinfo</field>
        <field name="inherit_id" ref="purchase.product_supplierinfo_tree_view2"/>
        <field name="priority">102</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='price']" position="attributes">
                <attribute name="string">Giá nguyên tệ</attribute>
            </xpath>
        </field>
    </record>

</odoo>
