<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Extend product search view -->
    <record id="product_template_search_inherit_custom" model="ir.ui.view">
        <field name="name">product.template.search.inherit.custom</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="priority">101</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='attribute_line_ids']" position="attributes">
                <attribute name="domain">['|', ('product_tmpl_id.product_type', '!=', 'lens'), ('attribute_id.name',
                    'not in', ('SPH','CYL','ADD'))]
                </attribute>
            </xpath>
        </field>
    </record>

    <!-- Ẩn categ_id trong product_template_form_view (form chính) -->
    <record id="product_template_form_hide_categ" model="ir.ui.view">
        <field name="name">product.template.form.hide.categ</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='categ_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="product_template_form_inherit_product" model="ir.ui.view">
        <field name="name">product.template.form.inherit.product</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">

            <xpath expr="//page[@name='general_information']//field[@name='default_code']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Ẩn Danh mục Avatax -->
            <xpath expr="//field[@name='avatax_category_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Ẩn categ_id mặc định của Odoo (đã có trong section Phân loại sản phẩm) -->
            <xpath expr="//page[@name='general_information']//field[@name='categ_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Add hidden computed fields for UI logic -->
            <xpath expr="//div[@class='oe_title']" position="after">
                <field name="is_lens" invisible="1"/>
                <field name="is_opt" invisible="1"/>
            </xpath>

            <!-- Ẩn tab Thuộc tính & Biến thể cho lens và gọng kính -->
            <xpath expr="//page[.//field[@name='attribute_line_ids']]" position="attributes">
                <attribute name="invisible">is_lens or is_opt</attribute>
            </xpath>

            <!-- Removed product_type selection from header -->

            <!-- Add Giá & Bảo hành into Sales tab (not general_information) -->
            <xpath expr="//page[@name='sales']" position="inside">
                <group string="Thông tin giá">
                    <group>
                        <field name="x_ws_price" string="Giá sỉ"/>
                        <field name="x_ws_price_min" string="Giá sỉ tối thiểu"/>
                        <field name="x_ws_price_max" string="Giá sỉ tối đa"/>
                        <field name="gia_si_theo_phan_tram" string="Giá sỉ theo %"/>
                    </group>
                </group>
            </xpath>

            <!-- Add Product General Info Section -->
            <xpath expr="//sheet/notebook/page[@name='general_information']/group" position="before">
                <!-- ── Thông tin chung ── -->
                <group string="Thông tin chung">
                    <group>
                        <field name="default_code" string="Mã viết tắt"/>
                        <field name="categ_id" string="Danh mục" options="{'no_create': True}"/>
                        <field name="lens_group_id" invisible="product_type != 'lens'" options="{'no_create': True}"/>
                        <field name="opt_group_id" invisible="product_type != 'opt'" options="{'no_create': True}"/>
                        <field name="acc_group_id" invisible="product_type != 'accessory'" options="{'no_create': True}"/>
                        <field name="brand_id"/>
                        <field name="country_id" string="Xuất xứ" options="{'no_create': True}"/>
                        <field name="uom_id" string="Đơn vị tính" options="{'no_create': True}"/>
                        <field name="index_id" options="{'no_create': True}" invisible="1"/>
                    </group>
                    <group>
                        <field name="status_product_id" options="{'no_create': True}"/>
                        <field name="x_eng_name"/>
                        <field name="auto_generate_code"/>
                        <field name="warranty_id" string="Bảo hành hãng" options="{'no_create': True}"/>
                        <field name="warranty_supplier_id" options="{'no_create': True}"/>
                        <field name="warranty_retail_id" options="{'no_create': True}"/>
                    </group>
                </group>

                <!-- ── Thiết kế Tròng (chỉ hiện khi is_lens) ── -->
                <group string="Thiết kế Tròng" invisible="not is_lens">
                    <group>
                        <field name="lens_sph_id" string="SPH" options="{'no_create': False}"/>
                        <field name="lens_cyl_id" string="CYL" options="{'no_create': False}"/>
                        <field name="lens_add_id" string="ADD" options="{'no_create': False}"/>
                        <field name="x_axis" string="Axis"/>
                        <field name="x_diameter" string="Đường kính (mm)"/>
                    </group>
                    <group>
                        <field name="lens_design1_id" string="Thiết kế 1" options="{'no_create': False}"/>
                        <field name="lens_design2_id" string="Thiết kế 2" options="{'no_create': False}"/>
                        <field name="x_prism" string="Lăng kính"/>
                        <field name="x_prism_base" string="Đáy lăng kính"/>
                    </group>
                </group>

                <!-- ── Chất liệu &amp; Tích hợp Tròng (chỉ hiện khi is_lens) ── -->
                <group string="Chất liệu &amp; Tích hợp" invisible="not is_lens">
                    <group>
                        <field name="lens_material_id" string="Vật liệu" options="{'no_create': False}"/>
                        <field name="lens_index_id" string="Chiết suất" options="{'no_create': False}"/>
                        <field name="lens_uv_id" string="UV" options="{'no_create': False}"/>
                        <field name="lens_coating_ids" string="Coating" widget="many2many_tags" options="{'no_create': False}"/>
                    </group>
                    <group>
                        <field name="lens_cl_hmc_id" string="HMC" options="{'no_create': False}"/>
                        <field name="lens_cl_pho_id" string="Photochromic" options="{'no_create': False}"/>
                        <field name="lens_cl_tint_id" string="Tinted" options="{'no_create': False}"/>
                    </group>
                </group>
            </xpath>

            <!-- Add custom tabs to notebook -->
            <xpath expr="//notebook" position="inside">

                <!-- ══════════════════════════════════════════════════════════
                     Tabs Lens (Hướng B: field trực tiếp trên template)
                     Hiển thị chỉ khi product_type = 'lens'
                     ══════════════════════════════════════════════════════════ -->

                <!-- Tab Legacy: product.lens cũ (chỉ hiện khi còn dữ liệu chưa migrate) -->
                <page string="⚠ Dữ liệu Cũ (product.lens)" name="product_lens_legacy"
                      invisible="not is_lens or not lens_ids">
                    <div class="alert alert-warning" role="alert">
                        <strong>⚠️ Dữ liệu Legacy:</strong>
                        Tab này hiển thị dữ liệu cũ từ model <em>product.lens</em>.
                        Hãy chạy wizard <b>Migrate Lens Data → Fields</b> (menu Cấu hình) để chuyển
                        sang các field mới ở tab <b>"Thiết kế Tròng"</b> / <b>"Chất liệu Tròng"</b> / <b>"Tích hợp
                        Tròng"</b>.
                    </div>
                    <field name="lens_ids" nolabel="1">
                        <list create="0" delete="0">
                            <field name="sph_id" string="SPH" readonly="1"/>
                            <field name="cyl_id" string="CYL" readonly="1"/>
                            <field name="lens_add" string="Add" readonly="1"/>
                            <field name="diameter" string="Đường kính" readonly="1"/>
                            <field name="material_id" string="Vật liệu" readonly="1"/>
                            <field name="index_id" string="Chiết suất" readonly="1"/>
                            <field name="uv_id" string="UV" readonly="1"/>
                            <field name="coating_ids" string="Coating" widget="many2many_tags" readonly="1"/>
                        </list>
                    </field>
                </page>

                <!-- ══════════════════════════════════════════════════════════
                     Tabs Gọng (Hướng B: field trực tiếp trên template)
                     Hiển thị chỉ khi is_opt = True
                     ══════════════════════════════════════════════════════════ -->

                <!-- Tab Gọng 1: Thông tin cơ bản -->
                <page string="Thông tin Gọng" name="product_opt_info"
                      invisible="not is_opt">
                    <group string="Thông tin chung">
                        <group>
                            <field name="opt_season"/>
                            <field name="opt_model"/>
                            <field name="opt_serial"/>
                            <field name="opt_sku"/>
                        </group>
                        <group>
                            <field name="opt_color" string="Mã màu"/>
                            <field name="opt_oem_ncc" string="Mã gốc NCC"/>
                        </group>
                    </group>
                </page>

                <!-- Tab Gọng 2: Thiết kế -->
                <page string="Thiết kế Gọng" name="product_opt_design"
                      invisible="not is_opt">
                    <group string="Kiểu dáng">
                        <group>
                            <field name="opt_frame_id" options="{'no_create': True}"/>
                            <field name="opt_frame_type_id" string="Kiểu loại" options="{'no_create': True}"/>
                            <field name="opt_shape_id" string="Kiểu dáng" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="opt_ve_id" options="{'no_create': True}"/>
                            <field name="opt_temple_id" options="{'no_create': True}"/>
                            <field name="opt_gender" string="Giới tính"/>
                        </group>
                    </group>
                </page>

                <!-- Tab Gọng 3: Vật liệu -->
                <page string="Vật liệu Gọng" name="product_opt_material"
                      invisible="not is_opt">
                    <group string="Vật liệu">
                        <group>
                            <field name="opt_materials_front_ids" string="Mặt trước" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                            <field name="opt_materials_temple_ids" string="Càng" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                            <field name="opt_material_temple_tip_id" string="Chuôi càng" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="opt_material_lens_id" string="Mắt kính" options="{'no_create': True}"/>
                            <field name="opt_material_ve_id" string="Ve kính" options="{'no_create': True}"/>
                            <field name="opt_coating_ids" string="Lớp mạ" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                </page>

                <!-- Tab Gọng 4: Màu sắc và Kích thước -->
                <page string="Màu sắc và kích thước Gọng" name="product_opt_color_size"
                      invisible="not is_opt">
                    <group string="Màu sắc">
                        <group>
                            <field name="opt_color_front_ids" string="Màu mặt trước"
                                   widget="many2many_tags" options="{'no_create': True}"/>
                            <field name="opt_color_temple_ids" string="Màu càng kính"
                                   widget="many2many_tags" options="{'no_create': True}"/>
                            <field name="opt_color_lens_id" string="Màu mắt kính (trường mắt)"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group string="Kích thước (mm)">
                        <group>
                            <field name="opt_temple_width"/>
                            <field name="opt_lens_width"/>
                            <field name="opt_bridge_width"/>
                        </group>
                        <group>
                            <field name="opt_lens_height"/>
                            <field name="opt_lens_span"/>
                        </group>
                    </group>
                </page>

                <!-- Tab Gọng 6: Bảo hành -->
                <page string="Bảo hành Gọng" name="product_opt_warranty"
                      invisible="1">
                    <group string="Chính sách bảo hành">
                        <group>
                            <field name="warranty_template_id"
                                   options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="manufacturer_months" string="Bảo hành hãng (tháng)"/>
                            <field name="company_months" string="Bảo hành công ty (tháng)"/>
                            <field name="bao_hanh_ban_le" string="Bảo hành bán lẻ (tháng)"/>
                        </group>
                    </group>
                </page>

                <!-- Tab Gọng 7: Phụ kiện đi kèm -->
                <page string="Phụ kiện đi kèm" name="product_opt_accessories"
                      invisible="not is_opt">
                    <group string="Phụ kiện">
                        <group>
                            <field name="has_box"/>
                            <field name="has_cleaning_cloth"/>
                            <field name="has_warranty_card"/>
                        </group>
                    </group>
                    <group string="Ghi chú">
                        <field name="accessory_note" nolabel="1"
                               placeholder="Ghi chú thêm về phụ kiện..."/>
                    </group>
                </page>

                <!-- Tabs Phụ kiện / Sản phẩm khác (không phải lens/opt) -->
                <page string="Thiết kế" name="accessory_design_tab" invisible="is_lens or is_opt">
                    <group>
                        <field name="design_id"/>
                        <field name="shape_id"/>
                    </group>
                </page>
                <page string="Vật liệu &amp; Màu sắc" name="accessory_material_color_tab" invisible="is_lens or is_opt">
                    <group>
                        <field name="material_id"/>
                        <field name="color_id"/>
                    </group>
                </page>
                <page string="Kích thước" name="accessory_size_tab" invisible="is_lens or is_opt">
                    <group>
                        <field name="acc_width" string="Chiều rộng"/>
                        <field name="acc_length" string="Chiều dài"/>
                        <field name="acc_height" string="Chiều cao"/>
                        <field name="acc_head" string="Đầu"/>
                        <field name="acc_body" string="Thân"/>
                    </group>
                </page>

            </xpath>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════
         CUSTOM INHERIT: fix view product (lens)
         1. default_code label → "Mã viết tắt"
         2. Ẩn index_id (trùng với lens_index_id)
         3. Thêm country_id vào tab Thông tin chung
         4. Đổi label price → "Giá nguyên tệ" trong tab Mua hàng
         5. Ẩn don_vi_nguyen_te khỏi view
         ══════════════════════════════════════════════════════════ -->

    <!-- country_id đã được thêm trực tiếp vào group "Phân loại sản phẩm" trong view product_template_form_inherit_product -->
    <!-- default_code label đổi trực tiếp trong view product_template_form_inherit_product bằng xpath -->

    <!-- 4. Đổi label cột "price" → "Giá nguyên tệ" trong bảng NCC (tab Mua hàng) -->
    <record id="view_product_supplierinfo_price_custom" model="ir.ui.view">
        <field name="name">product.supplierinfo.list.price.custom</field>
        <field name="model">product.supplierinfo</field>
        <field name="inherit_id" ref="purchase.product_supplierinfo_tree_view2"/>
        <field name="priority">102</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='price']" position="attributes">
                <attribute name="string">Giá nguyên tệ</attribute>
            </xpath>
        </field>
    </record>

</odoo>
