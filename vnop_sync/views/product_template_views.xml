<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Extend product search view to allow searching by short_code -->
    <record id="product_template_search_inherit_short_code" model="ir.ui.view">
        <field name="name">product.template.search.inherit.short_code</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="priority">101</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='attribute_line_ids']" position="attributes">
                <attribute name="domain">['|', ('product_tmpl_id.product_type', '!=', 'lens'), ('attribute_id.name', 'not in', ('SPH','CYL','ADD'))]</attribute>
            </xpath>
            <xpath expr="//field[@name='name']" position="after">
                <field name="short_code" string="Mã viết tắt" filter_domain="[('short_code', 'ilike', self)]"/>
            </xpath>
        </field>
    </record>

    <record id="product_template_form_inherit_product" model="ir.ui.view">
        <field name="name">product.template.form.inherit.product</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            
            <!-- Add hidden computed fields for UI logic -->
            <xpath expr="//div[@class='oe_title']" position="after">
                <field name="is_lens" invisible="1"/>
                <field name="is_opt" invisible="1"/>
            </xpath>

            <!-- Ẩn tab Thuộc tính & Biến thể cho lens (không dùng SPH/CYL/ADD variant) -->
            <xpath expr="//page[.//field[@name='attribute_line_ids']]" position="attributes">
                <attribute name="invisible">is_lens</attribute>
            </xpath>
            
            <!-- Removed product_type selection from header -->
            
            <!-- Add Giá & Bảo hành into Sales tab (not general_information) -->
            <xpath expr="//page[@name='sales']" position="inside">
                <group string="Giá bán sỉ">
                    <group>
                        <field name="don_vi_nguyen_te" string="Đơn vị ngoại tệ" options="{'no_create': True}"/>
                        <field name="x_or_price" string="Giá nhập kho (quy VNĐ)"/>
                    </group>
                    <group>
                        <field name="x_ws_price" string="Giá bán sỉ"/>
                        <field name="x_ws_price_min" string="Giá sỉ tối thiểu"/>
                        <field name="x_ws_price_max" string="Giá sỉ tối đa"/>
                        <field name="gia_si_theo_phan_tram" string="% giá sỉ" readonly="1"/>
                    </group>
                </group>
            </xpath>

            <!-- Add Product General Info Section -->
            <xpath expr="//sheet/notebook/page[@name='general_information']/group" position="before">
                <group string="Phân loại sản phẩm">
                    <group>
                        <field name="categ_id" string="Danh mục sản phẩm" options="{'no_create': True}"/>
                        <field name="group_id" invisible="1"/>
                        <field name="brand_id"/>
                        <field name="warranty_id" options="{'no_create': True}"/>
                        <field name="index_id" options="{'no_create': True}" 
                                invisible="not is_lens"/>
                    </group>
                    <group>
                        <field name="x_eng_name"/>
                        <field name="x_trade_name"/>
                        <field name="status_product_id" options="{'no_create': True}"/>
                        <field name="auto_generate_code"/>
                        <field name="default_code" readonly="auto_generate_code == True" invisible="1"/>
                    </group>
                </group>
            </xpath>
            
            <!-- Add custom tabs to notebook -->
            <xpath expr="//notebook" position="inside">

                <!-- ══════════════════════════════════════════════════════════
                     Tabs Lens (Hướng B: field trực tiếp trên template)
                     Hiển thị chỉ khi product_type = 'lens'
                     ══════════════════════════════════════════════════════════ -->

                <!-- Tab 1: Thiết kế Tròng -->
                <page string="Thiết kế Tròng" name="lens_design_tab"
                      invisible="not is_lens">
                    <group string="Thiết kế (Many2one)">
                        <group>
                            <field name="lens_design1_id" string="Thiết kế 1"
                                   options="{'no_create': False}"/>
                            <field name="lens_design2_id" string="Thiết kế 2"
                                   options="{'no_create': False}"/>
                        </group>
                    </group>
                    <group string="Công suất (Many2one)">
                        <group>
                            <field name="lens_sph_id" string="SPH"
                                   options="{'no_create': False}"/>
                            <field name="lens_cyl_id" string="CYL"
                                   options="{'no_create': False}"/>
                            <field name="lens_add_id" string="ADD"
                                   options="{'no_create': False}"/>
                            <field name="x_axis" string="Axis"/>
                        </group>
                        <group>
                            <field name="x_prism" string="Prism"/>
                            <field name="x_prism_base" string="Prism Base"/>
                            <field name="x_diameter" string="Đường kính (mm)"/>
                        </group>
                    </group>
                </page>

                <!-- Tab 2: Chất liệu & Tích hợp Tròng -->
                <page string="Chất liệu &amp; Tích hợp Tròng" name="lens_material_tab"
                      invisible="not is_lens">
                    <group string="Chất liệu &amp; Tích hợp">
                        <group>
                            <field name="lens_material_id" string="Vật liệu"
                                   options="{'no_create': False}"/>
                            <field name="lens_index_id" string="Chiết suất"
                                   options="{'no_create': False}"/>
                            <field name="lens_uv_id" string="UV"
                                   options="{'no_create': False}"/>
                            <field name="lens_coating_ids" string="Coating" widget="many2many_tags"
                                   options="{'no_create': False}"/>
                        </group>
                        <group>
                            <field name="x_hmc" string="HMC"/>
                            <field name="x_photochromic" string="Photochromic"/>
                            <field name="x_tinted" string="Tinted"/>
                        </group>
                    </group>
                </page>

                <!-- Tab Legacy: product.lens cũ (chỉ hiện khi còn dữ liệu chưa migrate) -->
                <page string="⚠ Dữ liệu Cũ (product.lens)" name="product_lens_legacy"
                      invisible="not is_lens or not lens_ids">
                    <div class="alert alert-warning" role="alert">
                        <strong>⚠️ Dữ liệu Legacy:</strong> Tab này hiển thị dữ liệu cũ từ model <em>product.lens</em>.
                        Hãy chạy wizard <b>Migrate Lens Data → Fields</b> (menu Cấu hình) để chuyển
                        sang các field mới ở tab <b>"Thiết kế Tròng"</b> / <b>"Chất liệu Tròng"</b> / <b>"Tích hợp Tròng"</b>.
                    </div>
                    <field name="lens_ids" nolabel="1">
                        <list create="0" delete="0">
                            <field name="sph_id" string="SPH" readonly="1"/>
                            <field name="cyl_id" string="CYL" readonly="1"/>
                            <field name="lens_add" string="Add" readonly="1"/>
                            <field name="diameter" string="Đường kính" readonly="1"/>
                            <field name="material_id" string="Vật liệu" readonly="1"/>
                            <field name="index_id" string="Chiết suất" readonly="1"/>
                            <field name="uv_id" string="UV" readonly="1"/>
                            <field name="coating_ids" string="Coating" widget="many2many_tags" readonly="1"/>
                        </list>
                    </field>
                </page>
                
                <!-- ══════════════════════════════════════════════════════════
                     Tabs Gọng (Hướng B: field trực tiếp trên template)
                     Hiển thị chỉ khi is_opt = True
                     ══════════════════════════════════════════════════════════ -->

                <!-- Tab Gọng 1: Thông tin cơ bản -->
                <page string="Thông tin Gọng" name="product_opt_info"
                      invisible="not is_opt">
                    <group string="Thông tin chung">
                        <group>
                            <field name="default_code" string="Mã sản phẩm"/>
                            <field name="opt_season"/>
                            <field name="opt_model"/>
                            <field name="opt_serial"/>
                            <field name="opt_sku"/>
                        </group>
                        <group>
                            <field name="opt_color" string="Mã màu"/>
                            <field name="opt_oem_ncc" string="Mã gốc NCC"/>
                        </group>
                    </group>
                </page>

                <!-- Tab Gọng 2: Thiết kế -->
                <page string="Thiết kế Gọng" name="product_opt_design"
                      invisible="not is_opt">
                    <group string="Kiểu dáng">
                        <group>
                            <field name="opt_frame_id" options="{'no_create': True}"/>
                            <field name="opt_frame_type_id" options="{'no_create': True}"/>
                            <field name="opt_shape_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="opt_ve_id" options="{'no_create': True}"/>
                            <field name="opt_temple_id" options="{'no_create': True}"/>
                            <field name="opt_gender" string="Giới tính"/>
                        </group>
                    </group>
                </page>

                <!-- Tab Gọng 3: Chất liệu -->
                <page string="Chất liệu Gọng" name="product_opt_material"
                      invisible="not is_opt">
                    <group string="Chất liệu">
                        <group>
                            <field name="opt_materials_front_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                            <field name="opt_materials_temple_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                            <field name="opt_material_temple_tip_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="opt_material_lens_id" options="{'no_create': True}"/>
                            <field name="opt_material_ve_id" options="{'no_create': True}"/>
                            <field name="opt_coating_ids" widget="many2many_tags"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                </page>

                <!-- Tab Gọng 4: Màu sắc -->
                <page string="Màu sắc Gọng" name="product_opt_color"
                      invisible="not is_opt">
                    <group string="Màu sắc">
                        <group>
                            <field name="opt_color_front_id" string="Màu mặt trước" options="{'no_create': True}"/>
                            <field name="opt_color_temple_id" string="Màu càng kính" options="{'no_create': True}"/>
                            <field name="opt_color_lens_id" string="Màu mắt kính (trường mắt)" options="{'no_create': True}"/>
                        </group>
                    </group>
                </page>

                <!-- Tab Gọng 5: Kích thước -->
                <page string="Kích thước Gọng" name="product_opt_size"
                      invisible="not is_opt">
                    <group string="Kích thước (mm)">
                        <group>
                            <field name="opt_temple_width"/>
                            <field name="opt_lens_width"/>
                            <field name="opt_bridge_width"/>
                        </group>
                        <group>
                            <field name="opt_lens_height"/>
                            <field name="opt_lens_span"/>
                        </group>
                    </group>
                </page>

                <!-- Tab Gọng 6: Bảo hành -->
                <page string="Bảo hành Gọng" name="product_opt_warranty"
                      invisible="not is_opt">
                    <group string="Chính sách bảo hành">
                        <group>
                            <field name="warranty_template_id"
                                   options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="manufacturer_months" string="Bảo hành hãng (tháng)"/>
                            <field name="company_months" string="Bảo hành công ty (tháng)"/>
                            <field name="bao_hanh_ban_le" string="Bảo hành bán lẻ (tháng)"/>
                        </group>
                    </group>
                </page>

                <!-- Tab Gọng 7: Phụ kiện đi kèm -->
                <page string="Phụ kiện đi kèm" name="product_opt_accessories"
                      invisible="not is_opt">
                    <group string="Phụ kiện">
                        <group>
                            <field name="has_box"/>
                            <field name="has_cleaning_cloth"/>
                            <field name="has_warranty_card"/>
                        </group>
                    </group>
                    <group string="Ghi chú">
                        <field name="accessory_note" nolabel="1"
                               placeholder="Ghi chú thêm về phụ kiện..."/>
                    </group>
                </page>

                <!-- Tab Legacy: product.opt cũ (chỉ hiện khi còn dữ liệu chưa migrate)
                <page string="⚠ Dữ liệu Cũ (product.opt)" name="product_opt_legacy"
                      invisible="not is_opt or not opt_ids">
                    <div class="alert alert-warning" role="alert">
                        <strong>⚠️ Dữ liệu Legacy:</strong> Tab này hiển thị dữ liệu cũ từ model <em>product.opt</em>.
                        Hãy chạy wizard <b>Migrate Opt Data → Fields</b> (menu Cấu hình) để chuyển
                        sang các field mới ở tab <b>"Thông tin Gọng"</b> / <b>"Thiết kế Gọng"</b> / v.v.
                    </div>
                    <field name="opt_ids" nolabel="1">
                        <list create="0" delete="0">
                            <field name="model" string="Model" readonly="1"/>
                            <field name="sku" string="SKU" readonly="1"/>
                            <field name="color" string="Màu" readonly="1"/>
                            <field name="frame_type_id" string="Loại gọng" readonly="1"/>
                            <field name="shape_id" string="Dáng" readonly="1"/>
                            <field name="material_ve_id" string="Chất liệu ve" readonly="1"/>
                        </list>
                    </field>
                </page>
                 -->
            </xpath>
        </field>
    </record>

</odoo>
