<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_product_import_wizard_form" model="ir.ui.view">
        <field name="name">product.import.wizard.form</field>
        <field name="model">product.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import sản phẩm từ Excel">
                <field name="state" invisible="1"/>

                <!-- Bước 1: Upload -->
                <group invisible="state != 'upload'">
                    <field name="product_type"/>
                    <field name="file_data" filename="file_name"/>
                    <field name="file_name" invisible="1"/>
                    <div colspan="2" class="text-muted">
                        <p>
                            <i class="fa fa-info-circle"/>
                            Hỗ trợ 2 định dạng:
                            <strong>Bảng mẫu kỹ thuật</strong> (header là technical field name)
                            và <strong>ItemLst quy ước PM</strong> (header nhãn tiếng Việt).
                            Hệ thống tự động nhận diện định dạng.
                        </p>
                    </div>
                </group>

                <!-- Bước 2: Kiểm thử -->
                <div invisible="state != 'preview'" class="p-3">
                    <field name="preview_text" widget="html" nolabel="1" readonly="1"/>

                    <div invisible="missing_ref_count == 0" class="mt-3">
                        <div class="alert alert-warning d-flex align-items-center justify-content-between">
                            <div>
                                <i class="fa fa-exclamation-triangle"/>
                                <strong> Master data còn thiếu:</strong>
                                <field name="missing_ref_count" nolabel="1" class="oe_inline ms-1 fw-bold"/>
                                giá trị. Bấm <strong>Tạo nhanh</strong> ở từng dòng hoặc
                                <strong>Tạo tất cả</strong>.
                            </div>
                            <button name="action_create_all_missing" type="object"
                                    string="Tạo tất cả" class="btn btn-warning"
                                    icon="fa-magic"/>
                        </div>
                        <field name="missing_ref_ids" nolabel="1">
                            <list editable="bottom" create="0" delete="0">
                                <field name="model_label" string="Bảng dữ liệu"
                                       readonly="1" optional="show"/>
                                <field name="field_label" string="Trường"
                                       readonly="1" optional="show"/>
                                <field name="value" string="Mã / cid"
                                       readonly="state == 'created'"/>
                                <field name="display_name_value" string="Tên đầy đủ"
                                       readonly="state == 'created'"/>
                                <field name="state" string="Trạng thái" readonly="1"
                                       widget="badge"
                                       decoration-warning="state == 'pending'"
                                       decoration-success="state == 'created'"/>
                                <field name="created_record_display"
                                       string="Đã tạo" readonly="1" optional="show"/>
                                <field name="model_name" column_invisible="1"/>
                                <field name="field_key" column_invisible="1"/>
                                <field name="search_field" column_invisible="1"/>
                                <button name="action_quick_create" type="object"
                                        string="Tạo nhanh" icon="fa-plus-circle"
                                        class="btn-link"
                                        invisible="state == 'created'"/>
                                <button name="action_open_record_form" type="object"
                                        string="Mở bản ghi" icon="fa-external-link"
                                        class="btn-link"
                                        invisible="state == 'pending'"/>
                            </list>
                        </field>
                    </div>
                </div>

                <!-- Bước 3: Kết quả import -->
                <div invisible="state != 'done'" class="p-3">
                    <group invisible="not error_text">
                        <field name="error_text" widget="text"/>
                    </group>

                    <group string="Tổng số đã tạo" invisible="not imported_count">
                        <group>
                            <field name="imported_count"/>
                        </group>
                        <group>
                            <field name="imported_lens_count"/>
                            <field name="imported_frame_count"/>
                            <field name="imported_accessory_count"/>
                            <field name="imported_other_count"
                                   invisible="imported_other_count == 0"/>
                        </group>
                    </group>

                    <field name="imported_product_ids"
                           invisible="not imported_product_ids"
                           nolabel="1"
                           readonly="1">
                        <list create="0" edit="0" delete="0">
                            <field name="barcode" string="Mã sản phẩm"/>
                            <field name="name"/>
                            <field name="classification_id"/>
                            <field name="classification_type"/>
                            <field name="brand_id"/>
                        </list>
                    </field>
                </div>

                <footer invisible="state != 'upload'">
                    <button name="action_test" type="object" string="Kiểm thử" class="btn-secondary" icon="fa-check-circle"/>
                    <button name="action_import" type="object" string="Import" class="btn-primary" icon="fa-upload"/>
                    <button string="Đóng" class="btn-secondary" special="cancel"/>
                </footer>
                <footer invisible="state != 'preview'">
                    <button name="action_back_upload" type="object" string="Quay lại" class="btn-secondary" icon="fa-arrow-left"/>
                    <button name="action_import" type="object" string="Import" class="btn-primary" icon="fa-upload"/>
                    <button string="Đóng" class="btn-secondary" special="cancel"/>
                </footer>
                <footer invisible="state != 'done'">
                    <button name="action_view_imported_products" type="object"
                            string="Xem sản phẩm đã tạo"
                            class="btn-primary" icon="fa-list"
                            invisible="not imported_product_ids"/>
                    <button name="action_back_upload" type="object" string="Import file khác" class="btn-secondary" icon="fa-arrow-left"/>
                    <button string="Đóng" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_product_import_wizard" model="ir.actions.act_window">
        <field name="name">Import sản phẩm từ Excel</field>
        <field name="res_model">product.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="view_product_import_wizard_form"/>
    </record>

</odoo>
