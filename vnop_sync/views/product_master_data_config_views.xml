<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ==================== ACCESSORY MASTER DATA ==================== -->
    <record id="view_product_design_tree" model="ir.ui.view">
        <field name="name">product.design.tree</field>
        <field name="model">product.design</field>
        <field name="arch" type="xml">
            <list editable="top" string="Thiết kế">
                <field name="cid"/>
                <field name="name"/>
                <field name="code"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_product_design_form" model="ir.ui.view">
        <field name="name">product.design.form</field>
        <field name="model">product.design</field>
        <field name="arch" type="xml">
            <form string="Thiết kế">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="cid"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_product_design" model="ir.actions.act_window">
        <field name="name">Thiết kế</field>
        <field name="res_model">product.design</field>
        <field name="view_mode">list,form</field>
    </record>

