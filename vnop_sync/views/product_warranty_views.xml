<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ============== ACTIONS SAU ============== -->
    <record id="action_product_template_warranty" model="ir.actions.act_window">
        <field name="name">Products</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('warranty_id', '=', active_id)]</field>
        <field name="context">{'default_warranty_id': active_id}</field>
    </record>

    <record id="action_product_warranty" model="ir.actions.act_window">
        <field name="name">Warranties</field>
        <field name="res_model">product.warranty</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ============== TREE/FORM VIEWS ============== -->
    <record id="view_product_warranty_tree" model="ir.ui.view">
        <field name="name">product.warranty.tree</field>
        <field name="model">product.warranty</field>
        <field name="arch" type="xml">
            <list string="Bảo hành">
                <field name="code"/>
                <field name="name"/>
                <field name="value"/>
            </list>
        </field>
    </record>

    <record id="view_product_warranty_form" model="ir.ui.view">
        <field name="name">product.warranty.form</field>
        <field name="model">product.warranty</field>
        <field name="arch" type="xml">
            <form string="Bảo hành">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                    </div>
                    <group>
                        <group>
                            <field name="name" placeholder="VD: Bảo hành 3 tháng"/>
                            <field name="code" placeholder="VD: BH3"/>
                        </group>
                        <group>
                            <field name="value"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Mô tả" name="description">
                            <field name="description" placeholder="Điều khoản bảo hành..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
