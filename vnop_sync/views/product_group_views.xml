<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Product Group Search View -->
    <record id="view_product_group_search" model="ir.ui.view">
        <field name="name">product.group.search</field>
        <field name="model">product.group</field>
        <field name="arch" type="xml">
            <search string="Tìm nhóm sản phẩm">
                <field name="name"/>
                <field name="cid"/>
                <field name="category_id"/>
                <separator/>
                <filter name="filter_dt" string="Đơn tròng" domain="[('product_type','=','DT')]"/>
                <filter name="filter_ht" string="Hai tròng" domain="[('product_type','=','HT')]"/>
                <filter name="filter_dat" string="Đa tròng" domain="[('product_type','=','DAT')]"/>
                <filter name="filter_pt" string="Phôi tròng" domain="[('product_type','=','PT')]"/>
                <filter name="filter_gk" string="Gọng kính" domain="[('product_type','=','GK')]"/>
                <filter name="filter_pk" string="Phụ kiện" domain="[('product_type','=','PK')]"/>
                <filter name="filter_lk" string="Linh kiện" domain="[('product_type','=','LK')]"/>
                <group expand="0" string="Nhóm theo">
                    <filter name="group_by_product_type" string="Phân loại" context="{'group_by': 'product_type'}"/>
                    <filter name="group_by_category" string="Danh mục" context="{'group_by': 'category_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Product Group Tree View -->
    <record id="view_product_group_tree" model="ir.ui.view">
        <field name="name">product.group.tree</field>
        <field name="model">product.group</field>
        <field name="arch" type="xml">
            <list string="Nhóm sản phẩm" editable="top" open_form_view="False">
                <field name="sequence"/>
                <field name="name"/>
                <field name="cid"/>
                <field name="description"/>
                <field name="product_type"/>
            </list>
        </field>
    </record>

    <!-- Product Group Action -->
    <record id="action_product_group" model="ir.actions.act_window">
        <field name="name">Nhóm sản phẩm</field>
        <field name="res_model">product.group</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_product_group_search"/>
    </record>
</odoo>
